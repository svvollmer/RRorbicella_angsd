# ============================================================================
# 18. GENE ANNOTATION OF OUTLIER REGIONS
# ============================================================================

GFF = config.get("gene_annotation", "reference/apalmata_genes.gff")

rule make_gene_bed:
    """Convert GFF gene entries to BED for intersection"""
    input:
        gff=GFF,
    output:
        bed="results/annotation/genes.bed",
        lookup="results/annotation/gene_lookup.csv",
    run:
        import re
        genes = []
        with open(input.gff) as f:
            for line in f:
                if line.startswith("#"):
                    continue
                parts = line.strip().split("\t")
                if len(parts) < 9 or parts[2] != "gene":
                    continue
                chrom = parts[0]
                start = int(parts[3]) - 1  # BED is 0-based
                end = int(parts[4])
                attrs = parts[8]
                
                name = ""
                desc = ""
                biotype = ""
                m = re.search(r'Name=([^;]+)', attrs)
                if m: name = m.group(1)
                m = re.search(r'description=([^;]+)', attrs)
                if m: desc = m.group(1)
                m = re.search(r'gene_biotype=([^;]+)', attrs)
                if m: biotype = m.group(1)
                
                genes.append({
                    "chrom": chrom, "start": start, "end": end,
                    "name": name, "description": desc, "biotype": biotype,
                })
        
        df = pd.DataFrame(genes)
        # BED file
        df[["chrom", "start", "end", "name"]].to_csv(
            output.bed, sep="\t", header=False, index=False)
        # Lookup table
        df.to_csv(output.lookup, index=False)

rule annotate_fst_outliers:
    """Find genes in FST outlier windows"""
    input:
        fst_windows="results/fst/{p1}_vs_{p2}.fst.global.windows",
        gene_bed="results/annotation/genes.bed",
        gene_lookup="results/annotation/gene_lookup.csv",
    output:
        outlier_windows="results/annotation/fst_{p1}_vs_{p2}_outlier_windows.csv",
        outlier_genes="results/annotation/fst_{p1}_vs_{p2}_outlier_genes.csv",
    params:
        percentile=config.get("fst_outlier_percentile", 0.99),
    run:
        # Read windowed FST
        fst = pd.read_csv(input.fst_windows, sep="\t", header=None,
                         names=["region", "chr", "midpoint", "n_sites", "fst"])
        fst = fst[fst["fst"] >= 0]
        
        # Get outlier threshold
        threshold = fst["fst"].quantile(params.percentile)
        outliers = fst[fst["fst"] >= threshold].copy()
        
        # Convert to BED (midpoint ± window/2)
        win_size = config.get("win_size", 50000)
        outliers["start"] = (outliers["midpoint"] - win_size // 2).astype(int).clip(lower=0)
        outliers["end"] = (outliers["midpoint"] + win_size // 2).astype(int)
        outliers.to_csv(output.outlier_windows, index=False)
        
        # Write temp BED for bedtools
        outlier_bed = output.outlier_windows + ".tmp.bed"
        outliers[["chr", "start", "end"]].to_csv(
            outlier_bed, sep="\t", header=False, index=False)
        
        # Intersect with genes using bedtools
        import subprocess
        result = subprocess.run(
            ["bedtools", "intersect", "-a", outlier_bed,
             "-b", input.gene_bed, "-wa", "-wb"],
            capture_output=True, text=True)
        
        # Parse results
        gene_lookup = pd.read_csv(input.gene_lookup)
        gene_dict = {row["name"]: row for _, row in gene_lookup.iterrows()}
        
        gene_records = []
        if result.stdout.strip():
            for line in result.stdout.strip().split("\n"):
                parts = line.split("\t")
                win_chr = parts[0]
                win_start = int(parts[1])
                win_end = int(parts[2])
                gene_name = parts[6] if len(parts) > 6 else ""
                
                # Get FST for this window
                win_fst = outliers[
                    (outliers["chr"] == win_chr) &
                    (outliers["start"] == win_start)
                ]["fst"].values
                fst_val = win_fst[0] if len(win_fst) > 0 else 0
                
                info = gene_dict.get(gene_name, {})
                gene_records.append({
                    "chromosome": win_chr,
                    "window_start": win_start,
                    "window_end": win_end,
                    "fst": round(fst_val, 4),
                    "gene_name": gene_name,
                    "description": info.get("description", ""),
                    "biotype": info.get("biotype", ""),
                })
        
        gene_df = pd.DataFrame(gene_records)
        gene_df.to_csv(output.outlier_genes, index=False)
        
        # Cleanup temp
        import os
        os.remove(outlier_bed)

rule immune_gene_enrichment:
    """Test if immune genes are enriched in FST outlier regions"""
    input:
        outlier_genes="results/annotation/fst_{p1}_vs_{p2}_outlier_genes.csv",
        gene_lookup="results/annotation/gene_lookup.csv",
    output:
        enrichment="results/annotation/fst_{p1}_vs_{p2}_enrichment.csv",
    run:
        from scipy import stats
        
        all_genes = pd.read_csv(input.gene_lookup)
        outlier_genes = pd.read_csv(input.outlier_genes)
        
        # Define gene categories to test
        categories = {
            "immune_TNF": "TNF",
            "immune_toll": "[Tt]oll",
            "immune_lectin": "lectin",
            "immune_complement": "complement",
            "immune_caspase": "caspase",
            "immune_interferon": "interferon",
            "immune_apoptosis": "apoptosis",
            "immune_interleukin": "interleukin",
            "immune_all": "TNF|[Tt]oll|lectin|complement|caspase|interferon|apoptosis|interleukin|immune",
            "stress_response": "heat shock|HSP|stress|chaperone",
            "signaling": "kinase|receptor|signal",
        }
        
        results = []
        total_genes = len(all_genes)
        total_outlier = len(outlier_genes["gene_name"].unique()) if len(outlier_genes) > 0 else 0
        
        for cat_name, pattern in categories.items():
            # Count in genome
            n_genome = len(all_genes[all_genes["description"].str.contains(pattern, case=False, na=False)])
            
            # Count in outlier regions
            if len(outlier_genes) > 0:
                n_outlier = len(outlier_genes[outlier_genes["description"].str.contains(pattern, case=False, na=False)]["gene_name"].unique())
            else:
                n_outlier = 0
            
            # Fisher's exact test (2x2: outlier/not × category/not)
            if total_genes > 0 and total_outlier > 0:
                table = [
                    [n_outlier, total_outlier - n_outlier],
                    [n_genome - n_outlier, total_genes - n_genome - total_outlier + n_outlier]
                ]
                try:
                    odds_ratio, pval = stats.fisher_exact(table, alternative="greater")
                except:
                    odds_ratio, pval = 1.0, 1.0
            else:
                odds_ratio, pval = 1.0, 1.0
            
            results.append({
                "category": cat_name,
                "pattern": pattern,
                "n_in_genome": n_genome,
                "n_in_outlier_regions": n_outlier,
                "total_genes_genome": total_genes,
                "total_genes_outliers": total_outlier,
                "odds_ratio": round(odds_ratio, 3),
                "pvalue": f"{pval:.2e}",
                "significant": "yes" if pval < 0.05 else "no",
            })
        
        pd.DataFrame(results).to_csv(output.enrichment, index=False)

# ============================================================================
# 19. GENERATE REPORT
# ============================================================================

rule generate_report:
    input:
        multiqc="results/multiqc/multiqc_report.html",
        depth="results/qc/depth_summary.csv",
        filter_summary="results/filtering/site_filter_summary.csv",
        repeat_stats="results/filtering/repeat_stats.txt",
        tstv="results/qc/tstv_ratio.txt",
        kinship="results/relatedness/pairwise_kinship.csv",
        genotypes="results/relatedness/unique_genotypes.csv",
        ld_decay="results/ld/ld_decay.csv",
        pca="results/pca/pcangsd.cov",
        best_k="results/admixture/best_k.txt",
        het=expand("results/heterozygosity/{sample}.het", sample=SAMPLES),
        thetas=expand("results/diversity/{popname}.thetas.idx.pestPG", popname=POPS),
        outlier_genes=expand("results/annotation/fst_{p1}_vs_{p2}_outlier_genes.csv",
                            p1=[p[0] for p in POP_PAIRS], p2=[p[1] for p in POP_PAIRS]),
        enrichment=expand("results/annotation/fst_{p1}_vs_{p2}_enrichment.csv",
                         p1=[p[0] for p in POP_PAIRS], p2=[p[1] for p in POP_PAIRS]),
    output:
        "deliverables/report.html",
    shell:
        """
        python scripts/generate_report.py \
            --results_dir results/ \
            --metadata {config[samples_csv]} \
            --output {output} \
            --output_dir deliverables/
        """
