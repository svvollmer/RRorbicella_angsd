rule bwa_map:
    container: "docker://quay.io/biocontainers/mulled-v2-bwa-samtools:0.7.17_1.17"
    input:
        r1="results/trimmed/{sample}_1.fastq.gz",
        r2="results/trimmed/{sample}_2.fastq.gz",
        ref=config["reference"],
        idx=multiext(config["reference"], ".amb", ".ann", ".bwt", ".pac", ".sa"),
    output:
        temp("results/bams/{sample}.raw.bam"),
    threads: 16
    shell:
        """
        bwa mem -t {threads} \
            -R '@RG\\tID:{wildcards.sample}\\tSM:{wildcards.sample}\\tPL:ILLUMINA' \
            {input.ref} {input.r1} {input.r2} \
        | samtools sort -@ 4 -m 2G -o {output} -
        """

rule mark_duplicates:
    container: "docker://quay.io/biocontainers/mulled-v2-bwa-samtools:0.7.17_1.17"
    input:
        "results/bams/{sample}.raw.bam",
    output:
        bam="results/bams/{sample}.dedup.bam",
        bai="results/bams/{sample}.dedup.bam.bai",
        metrics="results/qc/{sample}.dedup_metrics.txt",
    threads: 4
    shell:
        """
        samtools sort -n -@ {threads} {input} \
        | samtools fixmate -m - - \
        | samtools sort -@ {threads} - \
        | samtools markdup - {output.bam}
        samtools index -@ {threads} {output.bam}
        samtools flagstat {output.bam} > {output.metrics}
        """

