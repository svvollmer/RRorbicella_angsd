rule all:
    input:
        # QC & Filtering
        "results/multiqc/multiqc_report.html",
        "results/filtering/filtering_summary.txt",
        "results/qc/depth_summary.txt",

        # Two-pass ANGSD outputs
        "results/angsd/pass1_snps.txt",
        "results/angsd/all.beagle.gz",
        "results/angsd/all.mafs.gz",

        # LD analysis
        "results/ld/ld_decay.csv",
        "results/ld/ld_prune_window.txt",
        "results/angsd/all.ldpruned.beagle.gz",

        # PCA & Admixture (uses LD-pruned SNPs)
        "results/pca/pcangsd.cov",
        expand("results/admixture/pcangsd_K{k}.Q", k=range(2, config.get("max_k", 5) + 1)),

        # Diversity & FST (uses all sites via SAF)
        expand("results/diversity/{popname}.thetas.idx.pestPG", popname=POPS),
        [f"results/fst/{p[0]}_vs_{p[1]}.fst.global" for p in POP_PAIRS] if len(POPS) > 1 else [],

        # Individual analyses
        expand("results/heterozygosity/{sample}.het", sample=SAMPLES),
        "results/relatedness/relatedness_summary.txt",

        # Annotations
        "results/annotation/fst_outliers_annotated.csv",

        # Final report
        "results/report.html",

