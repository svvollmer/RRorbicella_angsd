rule fastp:
    container: "docker://quay.io/biocontainers/fastp:0.23.4--h5f740d0_0"
    input:
        r1="results/fastq/{sample}_1.fastq.gz",
        r2="results/fastq/{sample}_2.fastq.gz",
    output:
        r1=temp("results/trimmed/{sample}_1.fastq.gz"),
        r2=temp("results/trimmed/{sample}_2.fastq.gz"),
        html="results/qc/{sample}_fastp.html",
        json="results/qc/{sample}_fastp.json",
    threads: 4
    resources:
        mem_mb=4000,
        runtime=60,
    shell:
        """
        fastp -i {input.r1} -I {input.r2} \
            -o {output.r1} -O {output.r2} \
            -h {output.html} -j {output.json} \
            --thread {threads} \
            --detect_adapter_for_pe \
            --cut_front --cut_tail \
            --trim_poly_g
        """

