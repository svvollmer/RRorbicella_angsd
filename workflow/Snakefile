"""
================================================================================
ECOS Population Genomics Pipeline - Optimized Two-Pass ANGSD Workflow
================================================================================

Author: Vollmer Lab, Florida Atlantic University
Purpose: Production coral genomics pipeline for RealOmics

Workflow:
  Stage 1: BAM Processing (mapping, filtering, QC)
  Stage 2A: SNP Discovery → GL → LD → PCA/Admixture/Relatedness
  Stage 2B: SAF → SFS → Diversity/FST (uses all sites)

Key optimizations:
- Two-pass ANGSD (discovery 2hrs → GL 30min vs single-pass 18hrs)
- Individual depth filters prevent bad samples
- LD pruning before PCA/Admixture (scientifically correct)
- PCAngsd for both PCA and admixture (faster than NGSadmix)
- Data-driven filters based on sample size

Usage:
  snakemake --snakefile workflow/Snakefile --profile profiles/local
  snakemake --snakefile workflow/Snakefile --profile profiles/slurm
  snakemake --snakefile workflow/Snakefile --profile profiles/aws

================================================================================
"""

import pandas as pd
import numpy as np
from itertools import combinations

configfile: "config/config.yaml"

# Ensure conda env tools and standard utilities are on PATH in every shell job
shell.executable("/bin/bash")
shell.prefix("export PATH=/home/minipc/miniconda3/envs/angsd-pipeline/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH; ")

# Load samples
samples = pd.read_csv(config["samples_csv"])
SAMPLES = samples["sample_id"].tolist()
POPS = samples[config.get("primary_grouping", "population")].unique().tolist()
POP_PAIRS = list(combinations(sorted(POPS), 2))

# Calculate data-driven filter defaults
N_SAMPLES = len(SAMPLES)
MIN_DEPTH_TOTAL = N_SAMPLES * 2  # 2 reads per sample minimum
MIN_IND_DISCOVERY = int(N_SAMPLES * 0.6)  # 60% for discovery
MIN_IND_FINAL = int(N_SAMPLES * 0.8)  # 80% for final
SINGLETON_MAF = 1.0 / (2 * N_SAMPLES)  # Singleton frequency

def get_sra(wc):
    return samples.loc[samples["sample_id"] == wc.sample, "sra_accession"].values[0]

def get_pop_samples(wc):
    s = samples.loc[samples[config.get("primary_grouping", "population")] == wc.popname, "sample_id"].tolist()
    return expand("results/bams/{sample}.dedup.bam", sample=s)

