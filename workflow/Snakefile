        """

rule process_relatedness:
    input:
        "results/relatedness/relatedness.res",
    output:
        matrix="results/relatedness/relatedness_matrix.txt",
        summary="results/relatedness/relatedness_summary.txt",
    params:
        kinship_threshold=config.get("kinship_threshold", 0.2),
        clone_threshold=config.get("clone_threshold", 0.45),
    run:
        import pandas as pd
        rel = pd.read_csv(input[0], sep='\t')

        matrix = pd.DataFrame(0.0, index=SAMPLES, columns=SAMPLES)
        for _, row in rel.iterrows():
            i, j = int(row['a']), int(row['b'])
            if i < len(SAMPLES) and j < len(SAMPLES):
                matrix.iloc[i, j] = row['KING']
                matrix.iloc[j, i] = row['KING']
        matrix.to_csv(output.matrix, sep='\t')

        with open(output.summary, 'w') as f:
            f.write("Sample_A\tSample_B\tKING\tRelationship\n")
            for _, row in rel.iterrows():
                king = row['KING']
                if king > params.clone_threshold:
                    relationship = "Clone/Identical"
                elif king > params.kinship_threshold:
                    relationship = "Close_relative"
                else:
                    continue
                ia, ib = int(row['a']), int(row['b'])
                if ia < len(SAMPLES) and ib < len(SAMPLES):
                    f.write(f"{SAMPLES[ia]}\t{SAMPLES[ib]}\t{king:.4f}\t{relationship}\n")

# ============================================================================
# 11b. CLONE FILTER + BEAGLE SUBSETTING
# ============================================================================

rule filter_clones:
    """
    Identify clone pairs and close relatives; write a recommendations report.

    Does NOT auto-exclude — writes clones_report.txt with recommended exclusions
    so the investigator can review via the interactive clone_approve.py script.

    Clone GATE: after this rule runs, execute:
      python workflow/scripts/clone_approve.py
    which writes unrelated_samples.txt (required by downstream rules).
    """
    input:
        summary="results/relatedness/relatedness_summary.txt",
        depths=expand("results/qc/{sample}.depth.txt", sample=SAMPLES),
    output:
        "results/relatedness/clones_report.txt",
    params:
        clone_threshold=config.get("clone_threshold", 0.45),
        kinship_threshold=config.get("kinship_threshold", 0.2),
    run:
        import os, sys

        approved_file = "results/qc/samples_approved.txt"
        if os.path.exists(approved_file):
            with open(approved_file) as f:
                approved = [l.strip() for l in f
                            if l.strip() and not l.startswith('#') and not l.startswith('sample')]
        else:
            approved = list(SAMPLES)

        depths = {}
        for fpath in input.depths:
            sample = os.path.basename(fpath).replace('.depth.txt', '')
            with open(fpath) as f:
                depths[sample] = float(f.read().strip())

        clones    = []   # (a, b, king, depth_a, depth_b, recommended_exclude)
        relatives = []   # (a, b, king, relationship)

        with open(input.summary) as f:
            next(f)
            for line in f:
                parts = line.strip().split('\t')
                if len(parts) < 4:
                    continue
                a, b, king, rel = parts[0], parts[1], float(parts[2]), parts[3]
                da, db = depths.get(a, 0.0), depths.get(b, 0.0)
                if king >= params.clone_threshold:
                    rec = b if da >= db else a
                    clones.append((a, b, king, da, db, rec))
                elif king >= params.kinship_threshold:
                    relatives.append((a, b, king, rel))

        with open(output[0], 'w') as f:
            f.write("# clones_report.txt — generated by filter_clones rule\n")
            f.write("# Run: python workflow/scripts/clone_approve.py\n")
            f.write(f"# clone_threshold: {params.clone_threshold}\n")
            f.write(f"# kinship_threshold: {params.kinship_threshold}\n")
            f.write("\n[approved]\n")
            f.write("sample_id\tmean_depth\n")
            for s in approved:
                f.write(f"{s}\t{depths.get(s, 0.0):.2f}\n")
            f.write("\n[clones]\n")
            f.write("sample_a\tsample_b\tKING\tdepth_a\tdepth_b\trecommended_exclude\n")
            for row in clones:
                f.write("\t".join(str(x) for x in row) + "\n")
            f.write("\n[relatives]\n")
            f.write("sample_a\tsample_b\tKING\trelationship\n")
            for row in relatives:
                f.write("\t".join(str(x) for x in row) + "\n")

        n_clones = len(clones)
        n_rel    = len(relatives)
        print(
            f"\n{'='*60}\n"
            f"CLONE GATE: {n_clones} clone pair(s), {n_rel} close relative(s) found.\n"
            f"Run the interactive clone approval script:\n"
            f"  python workflow/scripts/clone_approve.py\n"
            f"Then re-run snakemake to continue.\n"
            f"{'='*60}\n",
            file=sys.stderr
        )

rule subset_beagle:
    """
    Remove clone/related-sample columns from the full beagle file.

    Beagle column layout: marker, Allele1, Allele2, then 3 cols per sample in
    the same order as make_bamlist_all (approved samples in SAMPLES order).
    """
    input:
        beagle="results/angsd/all.beagle.gz",
        clones_report="results/relatedness/clones_report.txt",
    output:
        beagle="results/angsd/all.unrelated.beagle.gz",
    run:
        import gzip, os, sys

        unrelated_file = "results/relatedness/unrelated_samples.txt"
        if not os.path.exists(unrelated_file):
            raise FileNotFoundError(
                f"\n{'='*60}\n"
                f"CLONE GATE: unrelated_samples.txt not found.\n"
                f"Run: python workflow/scripts/clone_approve.py\n"
                f"Then re-run snakemake.\n"
                f"{'='*60}"
            )

        approved_file = "results/qc/samples_approved.txt"
        if os.path.exists(approved_file):
            with open(approved_file) as f:
                approved = [l.strip() for l in f
                            if l.strip() and not l.startswith('#') and not l.startswith('sample')]
        else:
            approved = list(SAMPLES)

        with open(unrelated_file) as f:
            unrelated = set(l.strip() for l in f if l.strip())

        # 3 columns per sample; first 3 cols are marker/allele1/allele2
        keep_cols = [0, 1, 2]
        for i, sample in enumerate(approved):
            if sample in unrelated:
                keep_cols += [3 + i*3, 3 + i*3 + 1, 3 + i*3 + 2]

        n_removed = len(approved) - len(unrelated & set(approved))
        print(f"subset_beagle: removing {n_removed} clone samples", file=sys.stderr)

        with gzip.open(input.beagle, 'rt') as fin, \
             gzip.open(output.beagle, 'wt') as fout:
            fout.write(fin.readline())  # header
            for line in fin:
                parts = line.rstrip('\n').split('\t')
                fout.write('\t'.join(parts[i] for i in keep_cols) + '\n')

# ============================================================================
# 12. PER-POPULATION SAF → SFS → DIVERSITY → FST
# (Uses ALL sites at discovered positions, not SNP-filtered)
# ============================================================================

rule angsd_saf:
    """
    Per-population site allele frequency likelihoods over all non-repeat sites.

    Uses nonrepeat_sites.txt (-sites) to restrict to soft-masked non-repeat
    positions. Includes monomorphic sites — required for unbiased SFS and
    accurate diversity estimates (π, θ, Tajima's D). Restricting to SNPs
    would inflate diversity and bias Tajima's D positive.

    A. palmata reference serves as outgroup/ancestral state for A. cervicornis
    data, so unfolded SFS via -anc {ref} is valid.

    Runtime: 30-45 min per population (whole genome)
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h13024bc_4"
    input:
        bamlist="results/bamlists/{popname}.bamlist",
        ref=config["reference"],
        fai=config["reference"] + ".fai",
        depth_thresh="results/angsd/depth_thresholds.txt",
        sites="results/angsd/pass1_snps.txt",
        sites_idx="results/angsd/pass1_snps.txt.idx",
    output:
        saf="results/sfs/{popname}.saf.idx",
    params:
        out="results/sfs/{popname}",
        gl=config.get("gl_model", 1),
        max_depth=lambda wc, input: int([l.split()[1] for l in open(input.depth_thresh) if l.startswith('total_max')][0]),
        max_depth_ind=lambda wc, input: int([l.split()[1] for l in open(input.depth_thresh) if l.startswith('per_ind')][0]),
    threads: 8
    resources:
        mem_mb=16000,
        runtime=90,
    shell:
        """
        mkdir -p results/sfs
        angsd -bam {input.bamlist} -ref {input.ref} -anc {input.ref} \
            -out {params.out} \
            -GL {params.gl} -doSaf 1 -doCounts 1 \
            -setMaxDepth {params.max_depth} \
            -setMaxDepthInd {params.max_depth_ind} \
            -setMinDepthInd 2 \
            -minMapQ 20 -minQ 20 \
            -remove_bads 1 -only_proper_pairs 1 \
            -sites {input.sites} \
            -nThreads {threads}
        """

rule realsfs:
    """
    1D SFS via ML (EM algorithm). Runtime: 8-12 min per population.
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h13024bc_4"
    input:
        "results/sfs/{popname}.saf.idx",
    output:
        "results/sfs/{popname}.sfs",
    threads: 8
    resources:
        mem_mb=8000,
        runtime=30,
    shell:
        "realSFS {input} -P {threads} > {output}"

rule thetas:
    """
    π, θ, Tajima's D from SFS-weighted SAF. Runtime: 5-8 min per population.
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h13024bc_4"
    input:
        saf="results/sfs/{popname}.saf.idx",
        sfs="results/sfs/{popname}.sfs",
    output:
        idx="results/diversity/{popname}.thetas.idx",
        pestpg="results/diversity/{popname}.thetas.idx.pestPG",
    params:
        out="results/diversity/{popname}",
    threads: 8
    resources:
        mem_mb=8000,
        runtime=30,
    shell:
        """
        mkdir -p results/diversity
        realSFS saf2theta {input.saf} -sfs {input.sfs} -outname {params.out} -P {threads}
        thetaStat do_stat {output.idx}
        """

rule realsfs_2d:
    """
    2D SFS (joint SFS for two populations). Used as prior for FST.
    Runtime: 15-20 min per population pair.
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h13024bc_4"
    input:
        saf1="results/sfs/{p1}.saf.idx",
        saf2="results/sfs/{p2}.saf.idx",
    output:
        "results/fst/{p1}_vs_{p2}.2dsfs",
    threads: 8
    resources:
        mem_mb=16000,
        runtime=30,
    shell:
        """
        mkdir -p results/fst
        realSFS {input.saf1} {input.saf2} -P {threads} > {output}
        """

rule fst_index:
    container: "docker://quay.io/biocontainers/angsd:0.940--h13024bc_4"
    input:
        saf1="results/sfs/{p1}.saf.idx",
        saf2="results/sfs/{p2}.saf.idx",
        sfs="results/fst/{p1}_vs_{p2}.2dsfs",
    output:
        "results/fst/{p1}_vs_{p2}.fst.idx",
    params:
        out="results/fst/{p1}_vs_{p2}",
    shell:
        "realSFS fst index {input.saf1} {input.saf2} -sfs {input.sfs} -fstout {params.out}"

rule fst_global:
    """
    Global FST + windowed FST (50kb windows, 10kb step).
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h13024bc_4"
    input:
        "results/fst/{p1}_vs_{p2}.fst.idx",
    output:
        fst_global="results/fst/{p1}_vs_{p2}.fst.global",
        windows="results/fst/{p1}_vs_{p2}.fst.windows",
    shell:
        """
        realSFS fst stats  {input} > {output.fst_global}
        realSFS fst stats2 {input} -win 50000 -step 10000 -type 2 > {output.windows}
        """

