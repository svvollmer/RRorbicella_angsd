"""
================================================================================
ECOS Population Genomics Pipeline - Optimized Two-Pass ANGSD Workflow
================================================================================

Author: Vollmer Lab, Florida Atlantic University
Purpose: Production coral genomics pipeline for Acropora palmata

Workflow:
  Stage 1: BAM Processing (mapping, filtering, QC)
  Stage 2A: SNP Discovery → GL → LD → PCA/Admixture/Relatedness
  Stage 2B: SAF → SFS → Diversity/FST (uses all sites)

Key design decisions:
- Two-pass ANGSD: discovery (relaxed, whole genome) → GL (strict, SNPs only)
- Filtered reads stored as CRAM (~50% vs BAM) with embedded reference path
- dedup.bam is temp(): deleted once filtered.cram exists, saving disk during runs
- Sites index built once (index_sites rule) — avoids race condition with parallel jobs
- LD pruning via pure-Python greedy graph algorithm (no external deps)
- LD decay reads in chunks — safe for large files (96 samples × 100K SNPs)
- samtools coverage for depth — fast; samtools depth -a is 330M rows/sample
- resources: mem_mb + runtime on every rule — SLURM/AWS can schedule correctly

Usage:
  snakemake --snakefile workflow/Snakefile --profile profiles/local
  snakemake --snakefile workflow/Snakefile --profile profiles/slurm
  snakemake --snakefile workflow/Snakefile --profile profiles/aws

================================================================================
"""

import re
import pandas as pd
import numpy as np
from itertools import combinations

configfile: "config/config.yaml"

# When local_conda_env is set in config, prepend it to PATH in every shell job.
# Leave unset on HPC/AWS — Singularity containers provide the correct PATH.
import os
_conda_env = config.get("local_conda_env", "")
if _conda_env and os.path.isdir(_conda_env):   # only apply if path exists on this machine
    shell.executable("/bin/bash")
    shell.prefix(f"export PATH={_conda_env}/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH; ")

# Load samples
samples = pd.read_csv(config["samples_csv"])
SAMPLES = samples["sample_id"].tolist()
POPS = samples[config.get("primary_grouping", "population")].unique().tolist()
POP_PAIRS = list(combinations(sorted(POPS), 2))

# Prevent {popname} wildcard from matching "all" or other non-population strings,
# which would create cyclic dependencies with make_bamlist_all.
_pop_pattern = "|".join(re.escape(p) for p in POPS)
wildcard_constraints:
    popname=_pop_pattern,
    popname1=_pop_pattern,
    popname2=_pop_pattern,

# Data-driven filter thresholds
# Use approved sample count when available (post-QC gate); fall back to full CSV count.
N_SAMPLES = len(SAMPLES)
_approved_path = "results/qc/samples_approved.txt"
N_APPROVED = (
    sum(1 for l in open(_approved_path) if l.strip())
    if os.path.exists(_approved_path) else N_SAMPLES
)
MIN_DEPTH_TOTAL   = N_APPROVED * 2       # 2 reads per sample minimum across genome
MIN_IND_DISCOVERY = int(N_APPROVED * 0.6) # 60% of samples present — relaxed for discovery
MIN_IND_FINAL     = int(N_APPROVED * 0.8) # 80% of samples present — strict for GL

def get_sra(wc):
    return samples.loc[samples["sample_id"] == wc.sample, "sra_accession"].values[0]

def get_pop_samples(wc):
    s = samples.loc[samples[config.get("primary_grouping", "population")] == wc.popname,
                    "sample_id"].tolist()
    return expand("results/bams/{sample}.filtered.cram", sample=s)

