rule pcangsd_pca:
    """
    PCA analysis using LD-pruned SNPs
    - Uses independent SNPs to avoid bias from LD
    - Estimates covariance matrix for population structure

    Runtime: 10-15 minutes
    """
    container: "docker://quay.io/biocontainers/pcangsd:1.10--pyhdfd78af_1"
    input:
        "results/angsd/all.ldpruned.beagle.gz",
    output:
        cov="results/pca/pcangsd.cov",
    params:
        out="results/pca/pcangsd",
    threads: 8
    shell:
        """
        mkdir -p results/pca
        pcangsd -b {input} -o {params.out} -t {threads}
        """

rule pcangsd_admixture:
    """
    Admixture analysis using PCAngsd
    - Estimates ancestry proportions for K ancestral populations
    - Uses same LD-pruned SNPs as PCA
    - Faster than NGSadmix, handles LD better

    Runtime: 8-12 minutes per K
    """
    container: "docker://quay.io/biocontainers/pcangsd:1.10--pyhdfd78af_1"
    input:
        "results/angsd/all.ldpruned.beagle.gz",
    output:
        Q="results/admixture/pcangsd_K{k}.Q",
        F="results/admixture/pcangsd_K{k}.F.npy",
    params:
        out="results/admixture/pcangsd_K{k}",
    threads: 8
    shell:
        """
        mkdir -p results/admixture
        pcangsd -b {input} -o {params.out} --admix --admix_K {wildcards.k} -t {threads}

        # Rename output to match our convention
        mv {params.out}.admix.{wildcards.k}.Q {output.Q}
        mv {params.out}.admix.{wildcards.k}.F.npy {output.F}
        """

