# 13. INDIVIDUAL HETEROZYGOSITY
# ============================================================================

rule individual_saf:
    """
    Per-individual SAF for heterozygosity over all non-repeat sites.
    Reads CRAM directly — no bamlist needed for single-sample runs.
    sites_idx dependency ensures index is built before any of the 96 parallel jobs start.
    Runtime: 12-15 min per sample
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h13024bc_4"
    input:
        cram="results/bams/{sample}.filtered.cram",
        crai="results/bams/{sample}.filtered.cram.crai",
        ref=config["reference"],
        fai=config["reference"] + ".fai",
        depth_thresh="results/angsd/depth_thresholds.txt",
        sites="results/angsd/pass1_snps.txt",
        sites_idx="results/angsd/pass1_snps.txt.idx",
    output:
        temp("results/heterozygosity/{sample}.saf.idx"),
    params:
        out="results/heterozygosity/{sample}",
        gl=config.get("gl_model", 1),
        max_depth_ind=lambda wc, input: int([l.split()[1] for l in open(input.depth_thresh) if l.startswith('per_ind')][0]),
    threads: 4
    resources:
        mem_mb=8000,
        runtime=60,
    shell:
        """
        mkdir -p results/heterozygosity
        angsd -i {input.cram} -ref {input.ref} -anc {input.ref} \
            -GL {params.gl} -doSaf 1 -doCounts 1 \
            -setMaxDepthInd {params.max_depth_ind} \
            -setMinDepthInd 2 \
            -minMapQ 20 -minQ 20 \
            -remove_bads 1 -only_proper_pairs 1 \
            -sites {input.sites} \
            -nThreads {threads} -out {params.out}
        """

rule individual_het:
    """
    Genome-wide heterozygosity per sample from individual SAF.
    Runtime: 1-2 min per sample
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h13024bc_4"
    input:
        "results/heterozygosity/{sample}.saf.idx",
    output:
        "results/heterozygosity/{sample}.het",
    resources:
        mem_mb=4000,
        runtime=10,
    shell:
        "realSFS {input} > {output}"

