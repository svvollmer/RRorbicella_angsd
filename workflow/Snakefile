# 6. QC: DEPTH + MULTIQC
# ============================================================================

rule sample_depth:
    """
    samtools coverage is fast (one pass, per-chromosome summary).
    samtools depth -a was 330M rows per sample — too slow.
    Reports length-weighted mean depth across all chromosomes in the CRAM.
    """
    container: "docker://quay.io/biocontainers/mulled-v2-fe8faa35dbf6dc65a0f7f5d4ea12e31a79f73e40:219b6c272b25e7e642ae3ff0bf0c5c81a5135ab4-0"
    input:
        cram="results/bams/{sample}.filtered.cram",
        crai="results/bams/{sample}.filtered.cram.crai",
        ref=config["reference"],
        fai=config["reference"] + ".fai",
    output:
        "results/qc/{sample}.depth.txt",
    shell:
        """
        samtools coverage --reference {input.ref} {input.cram} \
            | awk 'NR>1 {{len+=$3-$2; dep+=$7*($3-$2)}} END {{printf "%.2f\\n", dep/len}}' \
            > {output}
        """

rule depth_summary:
    input:
        expand("results/qc/{sample}.depth.txt", sample=SAMPLES),
    output:
        "results/qc/depth_summary.txt",
    run:
        with open(output[0], 'w') as out:
            out.write("sample\tmean_depth\n")
            for f in input:
                sample = f.split('/')[-1].replace('.depth.txt', '')
                with open(f) as fh:
                    depth = fh.read().strip()
                out.write(f"{sample}\t{depth}\n")

rule compute_depth_thresholds:
    """
    Compute data-driven depth thresholds from actual per-sample coverage.

    ANGSD best practice: set -setMaxDepth and -setMaxDepthInd to mean + 2SD
    of observed per-sample depths. Prevents multi-mapping artifacts in
    repetitive regions from inflating depth without a hard arbitrary ceiling.

    per_ind_max  = ceil(mean + 2*SD), minimum 50x
    total_max    = N_samples * per_ind_max
    """
    input:
        depths=expand("results/qc/{sample}.depth.txt", sample=SAMPLES),
    output:
        "results/angsd/depth_thresholds.txt",
    run:
        import math
        depths = []
        for f in input.depths:
            with open(f) as fh:
                depths.append(float(fh.read().strip()))
        mean = sum(depths) / len(depths)
        sd = math.sqrt(sum((d - mean) ** 2 for d in depths) / len(depths))
        per_ind_max = max(50, math.ceil(mean + 2 * sd))
        total_max = N_APPROVED * per_ind_max
        with open(output[0], 'w') as out:
            out.write(f"total_max_depth\t{total_max}\n")
            out.write(f"per_ind_max_depth\t{per_ind_max}\n")
            out.write(f"mean_depth\t{mean:.2f}\n")
            out.write(f"sd_depth\t{sd:.2f}\n")

rule filtering_summary:
    input:
        expand("results/qc/{sample}.flagstat.txt", sample=SAMPLES),
        expand("results/qc/{sample}.depth.txt", sample=SAMPLES),
    output:
        "results/filtering/filtering_summary.txt",
    run:
        with open(output[0], 'w') as out:
            out.write("Sample\tTotal_reads\tMapped_reads\tMapping_rate\tMean_depth\n")
            for sample in SAMPLES:
                flagstat_file = f"results/qc/{sample}.flagstat.txt"
                depth_file    = f"results/qc/{sample}.depth.txt"
                with open(flagstat_file) as f:
                    lines  = f.readlines()
                    total  = lines[0].split()[0]
                    mapped = lines[6].split()[0]   # line 6 = "X mapped (N%)" (not line 4 = duplicates)
                    rate   = float(mapped) / float(total) if float(total) > 0 else 0
                with open(depth_file) as f:
                    depth = f.read().strip()
                out.write(f"{sample}\t{total}\t{mapped}\t{rate:.4f}\t{depth}\n")

rule multiqc:
    container: "docker://quay.io/biocontainers/multiqc:1.21--pyhdfd78af_0"
    input:
        expand("results/qc/{sample}_fastp.json", sample=SAMPLES),
        expand("results/qc/{sample}.flagstat.txt", sample=SAMPLES),
        expand("results/qc/{sample}.dedup_metrics.txt", sample=SAMPLES),
    output:
        "results/multiqc/multiqc_report.html",
    shell:
        """
        mkdir -p results/multiqc
        multiqc results/qc/ -o results/multiqc/ --force
        """

rule qc_report:
    """
    Per-sample QC outlier detection across depth, mapping rate, and duplicate rate.
    Flags samples > 2 SD from mean on any metric.

    Writes:
      - results/qc/qc_distribution.txt  : mean/SD/thresholds per metric
      - results/qc/samples_pass.txt     : all samples with flags (PASS or reason)

    QC GATE: Review samples_pass.txt, then create the approved sample list:
      cp results/qc/samples_pass.txt results/qc/samples_approved.txt
    Edit samples_approved.txt to remove problem samples (one sample_id per line),
    then re-run snakemake. All ANGSD/population analyses require this file.
    """
    input:
        summary="results/filtering/filtering_summary.txt",
        dedup=expand("results/qc/{sample}.dedup_metrics.txt", sample=SAMPLES),
    output:
        distribution="results/qc/qc_distribution.txt",
        pass_list="results/qc/samples_pass.txt",
    run:
        import math, os

        # Parse filtering summary: sample, total_reads, mapped_reads, mapping_rate, mean_depth
        stats = {}
        with open(input.summary) as f:
            next(f)
            for line in f:
                parts = line.strip().split('\t')
                sample, total, mapped, rate, depth = parts
                stats[sample] = {
                    'total_reads':   int(total),
                    'mapped_reads':  int(mapped),
                    'mapping_rate':  float(rate),
                    'mean_depth':    float(depth),
                    'dup_rate':      0.0,
                }

        # Parse duplicate rate from samtools flagstat (line index 3: "X + 0 duplicates")
        for fpath in input.dedup:
            sample = os.path.basename(fpath).replace('.dedup_metrics.txt', '')
            if sample not in stats:
                continue
            with open(fpath) as f:
                lines = f.readlines()
            total = int(lines[0].split()[0])
            dups  = int(lines[4].split()[0])   # line 4 = "X duplicates" (not line 3 = supplementary)
            stats[sample]['dup_rate'] = dups / total if total > 0 else 0.0

        def mean_sd(vals):
            m = sum(vals) / len(vals)
            sd = math.sqrt(sum((v - m) ** 2 for v in vals) / len(vals))
            return m, sd

        depths    = [stats[s]['mean_depth']   for s in SAMPLES if s in stats]
        rates     = [stats[s]['mapping_rate'] for s in SAMPLES if s in stats]
        dup_rates = [stats[s]['dup_rate']     for s in SAMPLES if s in stats]

        m_dep,  sd_dep  = mean_sd(depths)
        m_rate, sd_rate = mean_sd(rates)
        m_dup,  sd_dup  = mean_sd(dup_rates)

        with open(output.distribution, 'w') as f:
            f.write("metric\tmean\tsd\tmin_threshold\tmax_threshold\n")
            f.write(f"mean_depth\t{m_dep:.2f}\t{sd_dep:.2f}\t{m_dep-2*sd_dep:.2f}\t{m_dep+2*sd_dep:.2f}\n")
            f.write(f"mapping_rate\t{m_rate:.4f}\t{sd_rate:.4f}\t{m_rate-2*sd_rate:.4f}\tNA\n")
            f.write(f"dup_rate\t{m_dup:.4f}\t{sd_dup:.4f}\tNA\t{m_dup+2*sd_dup:.4f}\n")

        with open(output.pass_list, 'w') as f:
            f.write("sample_id\tmean_depth\tmapping_rate\tdup_rate\tflags\n")
            for sample in SAMPLES:
                if sample not in stats:
                    continue
                s = stats[sample]
                flags = []
                if s['mean_depth']   < m_dep  - 2 * sd_dep:  flags.append(f"low_depth({s['mean_depth']:.1f}x)")
                if s['mean_depth']   > m_dep  + 2 * sd_dep:  flags.append(f"high_depth({s['mean_depth']:.1f}x)")
                if s['mapping_rate'] < m_rate - 2 * sd_rate:  flags.append(f"low_mapping({s['mapping_rate']:.3f})")
                if s['dup_rate']     > m_dup  + 2 * sd_dup:  flags.append(f"high_dup({s['dup_rate']:.3f})")
                flag_str = ','.join(flags) if flags else 'PASS'
                f.write(f"{sample}\t{s['mean_depth']:.2f}\t{s['mapping_rate']:.4f}\t{s['dup_rate']:.4f}\t{flag_str}\n")

        print(
            f"\n{'='*60}\n"
            f"QC GATE: {len([s for s in SAMPLES if s in stats])} samples processed.\n"
            f"Run the interactive approval script:\n"
            f"  python workflow/scripts/qc_approve.py\n"
            f"Then re-run snakemake to continue.\n"
            f"{'='*60}\n",
            file=__import__('sys').stderr
        )

# ============================================================================
# 7. BAMLISTS
# ============================================================================

rule make_bamlist_all:
    """
    Bamlist for ANGSD discovery + GL passes. Uses all approved samples.

    QC GATE: Reads results/qc/samples_approved.txt at runtime (not a formal
    Snakemake input so alignment can proceed before user review). If missing,
    the job fails with instructions — re-run after creating the approved file.
    """
    input:
        crams=expand("results/bams/{sample}.filtered.cram", sample=SAMPLES),
        qc_pass="results/qc/samples_pass.txt",
    output:
        "results/bamlists/all.bamlist",
    run:
        import os, sys
        approved_file = "results/qc/samples_approved.txt"
        if not os.path.exists(approved_file):
            raise FileNotFoundError(
                f"\n{'='*60}\n"
                f"QC GATE: samples_approved.txt not found.\n"
                f"Run the interactive QC approval script:\n"
                f"  python workflow/scripts/qc_approve.py\n"
                f"Review flagged samples, confirm exclusions, then\n"
                f"re-run snakemake to continue.\n"
                f"{'='*60}"
            )
        with open(approved_file) as f:
            approved = set(l.strip() for l in f
                          if l.strip() and not l.startswith('#') and not l.startswith('sample'))
        with open(output[0], 'w') as f:
            for sample in SAMPLES:
                if sample in approved:
                    f.write(f"results/bams/{sample}.filtered.cram\n")

rule make_bamlist_pop:
    """
    Per-population bamlist for SAF/FST. Uses clone-filtered approved samples only.

    CLONE GATE: depends on clones_report.txt (ensures ngsRelate chain ran).
    Reads unrelated_samples.txt at runtime — run clone_approve.py if missing.
    """
    input:
        bams=get_pop_samples,
        clones_report="results/relatedness/clones_report.txt",
    output:
        "results/bamlists/{popname}.bamlist",
    run:
        import os
        unrelated_file = "results/relatedness/unrelated_samples.txt"
        if not os.path.exists(unrelated_file):
            raise FileNotFoundError(
                f"\n{'='*60}\n"
                f"CLONE GATE: unrelated_samples.txt not found.\n"
                f"Run the interactive clone approval script:\n"
                f"  python workflow/scripts/clone_approve.py\n"
                f"Then re-run snakemake to continue.\n"
                f"{'='*60}"
            )
        with open(unrelated_file) as f:
            unrelated = set(l.strip() for l in f if l.strip())
        with open(output[0], 'w') as f:
            for path in input.bams:
                sample = path.split('/')[-1].replace('.filtered.cram', '')
                if sample in unrelated:
                    f.write(str(path) + '\n')

# ============================================================================
# 8. TWO-PASS ANGSD: SNP DISCOVERY
# ============================================================================

rule make_angsd_sites:
    """
    Convert nonrepeat_regions.bed to ANGSD sites file (chr, pos 1-based) and index.

    All ANGSD rules use this file via -sites to restrict analysis to non-repeat
    positions. This replaces the former approach of pre-filtering CRAMs with -L,
    which discarded reads whose start fell in a repeat but covered non-repeat bases.

    Output: ~217M lines for A. palmata (~3 GB). Generation takes ~5 min via awk.
    ANGSD sites index creates .idx and .bin files for O(1) position lookup.
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h13024bc_4"
    input:
        bed="results/filtering/nonrepeat_regions.bed",
    output:
        sites="results/angsd/nonrepeat_sites.txt",
        idx="results/angsd/nonrepeat_sites.txt.idx",
        bin="results/angsd/nonrepeat_sites.txt.bin",
    resources:
        mem_mb=4000,
        runtime=30,
    shell:
        """
        mkdir -p results/angsd
        awk 'BEGIN{{OFS="\\t"}} {{for(i=$2+1; i<=$3; i++) print $1,i}}' {input.bed} \
            > {output.sites}
        angsd sites index {output.sites}
        """

rule angsd_discover_snps:
    """
    PASS 1: SNP Discovery — non-repeat sites, relaxed filters.

    Uses nonrepeat_sites.txt (-sites) to restrict analysis to soft-masked
    non-repeat positions, avoiding repeat-associated mapping artifacts.
    Depth filters (-setMaxDepth, -setMaxDepthInd) catch any residual
    multi-mapping pileups. -remove_bads 1 excludes duplicate/secondary/QC-fail
    reads at the ANGSD level. -only_proper_pairs 1 excludes chimeric pairs.

    Relaxed minInd (60%) and SNP p-value (1e-4) to capture all variable sites.
    Runtime: ~2h for 96 samples; ~50 min for 5 samples
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h13024bc_4"
    input:
        bamlist="results/bamlists/all.bamlist",
        ref=config["reference"],
        fai=config["reference"] + ".fai",
        chroms="results/filtering/chromosomes.bed",
        depth_thresh="results/angsd/depth_thresholds.txt",
        sites="results/angsd/nonrepeat_sites.txt",
        sites_idx="results/angsd/nonrepeat_sites.txt.idx",
    output:
        mafs="results/angsd/pass1.mafs.gz",
    params:
        out="results/angsd/pass1",
        min_ind=MIN_IND_DISCOVERY,
        min_depth=MIN_DEPTH_TOTAL,
        max_depth=lambda wc, input: int([l.split()[1] for l in open(input.depth_thresh) if l.startswith('total_max')][0]),
        max_depth_ind=lambda wc, input: int([l.split()[1] for l in open(input.depth_thresh) if l.startswith('per_ind')][0]),
    threads: 16
    resources:
        mem_mb=32000,
        runtime=180,
    shell:
        """
        mkdir -p results/angsd

        angsd -bam {input.bamlist} -ref {input.ref} \
            -out {params.out} \
            -GL 1 -doMajorMinor 1 -doMaf 1 \
            -doCounts 1 \
            -setMinDepth {params.min_depth} \
            -setMaxDepth {params.max_depth} \
            -setMinDepthInd 2 \
            -setMaxDepthInd {params.max_depth_ind} \
            -minInd {params.min_ind} \
            -minMapQ 20 -minQ 20 \
            -remove_bads 1 -only_proper_pairs 1 \
            -SNP_pval 1e-4 \
            -skipTriallelic 1 \
            -sites {input.sites} \
            -nThreads {threads}
        """

rule extract_snplist:
    """Extract chr+pos SNP list from pass1.mafs.gz (runs on host, no container)."""
    input:
        mafs="results/angsd/pass1.mafs.gz",
    output:
        snplist="results/angsd/pass1_snps.txt",
    run:
        import gzip
        with gzip.open(input.mafs, "rt") as f:
            next(f)
            with open(output.snplist, "w") as out:
                for line in f:
                    p = line.split("\t")
                    out.write(p[0] + "\t" + p[1] + "\n")

rule index_sites:
    """
    Index the SNP list exactly once.

    Without this, angsd_gl_snps, angsd_saf (one per population), and
    individual_saf (one per sample) would all race to write the same
    .bin and .idx files in parallel — silently corrupting the index.
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h13024bc_4"
    input:
        "results/angsd/pass1_snps.txt",
    output:
        bin="results/angsd/pass1_snps.txt.bin",
        idx="results/angsd/pass1_snps.txt.idx",
    shell:
        "angsd sites index {input}"

