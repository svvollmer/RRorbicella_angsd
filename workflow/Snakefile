rule make_chrom_regions:
    container: "docker://quay.io/biocontainers/mulled-v2-fe8faa35dbf6dc65a0f7f5d4ea12e31a79f73e40:219b6c272b25e7e642ae3ff0bf0c5c81a5135ab4-0"
    input:
        fai=config["reference"] + ".fai",
    output:
        bed="results/filtering/chromosomes.bed",
    params:
        min_size=config.get("min_scaffold_size", 10000000),
    shell:
        """
        awk '$2 >= {params.min_size} {{print $1"\\t0\\t"$2}}' {input.fai} > {output.bed}
        """

rule make_nonrepeat_bed:
    # No container — only needs python3 (host), not bwa/samtools
    input:
        ref=config["reference"],
        chroms="results/filtering/chromosomes.bed",
    output:
        bed="results/filtering/nonrepeat_regions.bed",
    resources:
        mem_mb=8000,
        runtime=30,
    shell:
        """
        python3 workflow/scripts/create_nonrepeat_bed.py \
            {input.ref} {input.chroms} {output.bed} \
            --min-length 100 --merge-gap 50
        """

rule filter_mapped:
    """
    Filter by MAPQ + chromosome-level scaffolds, write as CRAM.

    Reads are restricted to chromosome-level scaffolds (chromosomes.bed) but NOT
    pre-filtered to non-repeat intervals. Repeat exclusion is handled downstream
    by ANGSD via -sites (nonrepeat_sites.txt) and -setMaxDepth depth filters.
    This preserves reads spanning repeat/non-repeat boundaries that would otherwise
    be lost if filtering by read-start position against nonrepeat_regions.bed.

    Uses realpath to embed absolute reference path so CRAM is portable between rules.
    dedup.bam is deleted by Snakemake after this rule completes (marked temp).
    """
    container: "docker://quay.io/biocontainers/mulled-v2-fe8faa35dbf6dc65a0f7f5d4ea12e31a79f73e40:219b6c272b25e7e642ae3ff0bf0c5c81a5135ab4-0"
    input:
        bam="results/bams/{sample}.dedup.bam",
        bed="results/filtering/chromosomes.bed",
        ref=config["reference"],
        fai=config["reference"] + ".fai",
    output:
        cram="results/bams/{sample}.filtered.cram",
        crai="results/bams/{sample}.filtered.cram.crai",
    params:
        mapq=config.get("minmapq", 20),
    threads: 4
    resources:
        mem_mb=4000,
        runtime=60,
    shell:
        """
        REF=$(realpath {input.ref})
        samtools view -C -T $REF \
            -q {params.mapq} -L {input.bed} \
            -@ {threads} -o {output.cram} {input.bam}
        samtools index {output.cram}
        """

