        "results/qc/depth_summary.txt",
        "results/qc/samples_pass.txt",

        # Two-pass ANGSD outputs
        "results/angsd/pass1_snps.txt",
        "results/angsd/all.beagle.gz",
        "results/angsd/all.mafs.gz",

        # Clone filter (unrelated_samples.txt created by clone_approve.py, not tracked here)
        "results/relatedness/clones_report.txt",
