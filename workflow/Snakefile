    container: "docker://quay.io/biocontainers/mulled-v2-bwa-samtools:0.7.17_1.17"
    input:
        bams=get_pop_samples,
    output:
        "results/bamlists/{popname}.bamlist",
    shell:
        "echo {input.bams} | tr ' ' '\\n' > {output}"

rule angsd_discover_snps:
    """
    PASS 1: SNP Discovery (relaxed filters, whole chromosomes)

    Strategy: Process whole genome with relaxed filters to find all variable sites
    - Uses whole chromosomes (14 regions) not fragmented repeats (398K regions)
    - Depth filters catch multi-mapping reads (repeats)
    - Outputs SNP list for Pass 2

    Runtime: 1.5-2 hrs with --jobs 1, or 30-45 min with --jobs 4 (chromosome parallel)
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h2add14b_0"
    input:
        bamlist="results/bamlists/all.bamlist",
        ref=config["reference"],
        fai=config["reference"] + ".fai",
        chroms="results/filtering/chromosomes.bed",
    output:
        mafs="results/angsd/pass1.mafs.gz",
        snplist="results/angsd/pass1_snps.txt",
    params:
        out="results/angsd/pass1",
        min_ind=MIN_IND_DISCOVERY,
        min_depth=MIN_DEPTH_TOTAL,
        max_depth=1000,
    threads: 16
    shell:
        """
        mkdir -p results/angsd

        # Discovery with relaxed filters on whole chromosomes
        angsd -bam {input.bamlist} -ref {input.ref} \
            -out {params.out} \
            -GL 1 -doMajorMinor 1 -doMaf 2 \
            -doCounts 1 \
            -setMinDepth {params.min_depth} \
            -setMaxDepth {params.max_depth} \
            -setMinDepthInd 2 \
            -setMaxDepthInd 100 \
            -minInd {params.min_ind} \
            -minMapQ 20 -minQ 20 \
            -SNP_pval 1e-4 \
            -skipTriallelic 1 \
            -rf {input.chroms} \
            -nThreads {threads}

        # Extract SNP positions for Pass 2
        python3 -c "
import gzip, sys
with gzip.open('{output.mafs}', 'rt') as f:
    next(f)
    with open('{output.snplist}', 'w') as out:
        for line in f:
            p = line.split('\\t'); out.write(p[0]+'\\t'+p[1]+'\\n')
"
        """

rule angsd_gl_snps:
    """
    PASS 2: Genotype Likelihoods at discovered SNPs (strict filters)

    Strategy: Only process SNPs from Pass 1 with stringent filters
    - ~50-100K SNPs instead of 329 Mb genome
    - Much faster (30 min vs hours)
    - Creates beagle file for PCA/Admixture/LD/Relatedness

    Runtime: 20-30 minutes
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h2add14b_0"
    input:
        bamlist="results/bamlists/all.bamlist",
        ref=config["reference"],
        fai=config["reference"] + ".fai",
        sites="results/angsd/pass1_snps.txt",
    output:
        beagle="results/angsd/all.beagle.gz",
        mafs="results/angsd/all.mafs.gz",
    params:
        out="results/angsd/all",
        min_ind=MIN_IND_FINAL,
        min_maf=config.get("min_maf", 0.05),
    threads: 16
    shell:
        """
        # Index sites file
        angsd sites index {input.sites}

        # Calculate GLs at discovered SNPs with strict filters
        angsd -bam {input.bamlist} -ref {input.ref} \
            -out {params.out} \
            -GL 1 -doMajorMinor 1 -doMaf 1 -doGlf 2 \
            -sites {input.sites} \
            -minInd {params.min_ind} \
            -minMapQ 20 -minQ 20 \
            -SNP_pval 1e-6 \
            -minMaf {params.min_maf} \
            -skipTriallelic 1 \
            -nThreads {threads}
        """

# ============================================================================
# 7. LD ANALYSIS (must run before PCA/Admixture)
# ============================================================================

rule ngsld_estimate:
    """
    Estimate LD between all SNP pairs
    - Calculates r² for pairs within 500kb
    - Used to identify correlated SNPs for pruning

    Runtime: 25-35 minutes for ~75K SNPs
    """
    container: "docker://quay.io/biocontainers/ngsld:1.2.0--h2add14b_1"
    input:
        beagle="results/angsd/all.beagle.gz",
        mafs="results/angsd/all.mafs.gz",
    output:
        ld_raw=temp("results/ld/ld_raw.tsv"),
    params:
        max_dist_kb=config.get("ld_max_dist", 500000) // 1000,
        n_samples=N_SAMPLES,
    threads: 8
    shell:
        """
        mkdir -p results/ld
        N_SITES=$(python3 -c "import gzip; f=gzip.open('{input.mafs}','rt'); next(f); print(sum(1 for _ in f))")

        python3 -c "
import gzip
with gzip.open('{input.mafs}', 'rt') as f:
    next(f)
    with open('results/ld/snp_pos.txt', 'w') as out:
        for line in f:
            p = line.split('\\t'); out.write(p[0]+'\\t'+p[1]+'\\n')
"

        ngsLD --geno {input.beagle} \
            --probs --n_ind {params.n_samples} --n_sites $N_SITES \
            --max_kb_dist {params.max_dist_kb} \
            --pos results/ld/snp_pos.txt \
            --n_threads {threads} \
            > {output.ld_raw}
        """

rule ld_decay:
    """
    Analyze LD decay with distance
    - Bins LD by physical distance
    - Determines pruning window from decay curve

    Runtime: 2-5 minutes
    """
    input:
        "results/ld/ld_raw.tsv",
    output:
        decay="results/ld/ld_decay.csv",
        window="results/ld/ld_prune_window.txt",
    params:
        threshold=config.get("ld_decay_threshold", 0.1),
    run:
        import pandas as pd
        ld = pd.read_csv(input[0], sep='\t', header=None,
                        names=['chr1', 'pos1', 'chr2', 'pos2', 'r2'])
        ld['dist'] = abs(ld['pos2'] - ld['pos1'])

        bins = [0, 1000, 5000, 10000, 50000, 100000, 500000]
        ld['bin'] = pd.cut(ld['dist'], bins=bins)
        decay = ld.groupby('bin')['r2'].agg(['mean', 'median', 'count']).reset_index()
        decay.to_csv(output.decay, index=False)

        # Determine pruning window
        for i, row in decay.iterrows():
            if row['mean'] < params.threshold:
                window_kb = bins[i] / 1000
                with open(output.window, 'w') as f:
                    f.write(f"{window_kb}\n")
                break

rule ld_prune:
    """
    Create LD-pruned SNP set
    - Removes SNPs in high LD (r² > 0.3)
    - Greedy pruning algorithm

    Runtime: 2-3 minutes
    """
    input:
        ld="results/ld/ld_raw.tsv",
    output:
        "results/ld/pruned_snps.txt",
    params:
        r2_threshold=config.get("ld_r2_threshold", 0.3),
    run:
        import pandas as pd
        ld = pd.read_csv(input.ld, sep='\t', header=None,
                        names=['chr1', 'pos1', 'chr2', 'pos2', 'r2'])

        high_ld = ld[ld['r2'] > params.r2_threshold]

        # Greedy pruning
        remove_snps = set()
        for _, row in high_ld.iterrows():
            snp1 = f"{row['chr1']}:{row['pos1']}"
            snp2 = f"{row['chr2']}:{row['pos2']}"
            if snp1 not in remove_snps and snp2 not in remove_snps:
                remove_snps.add(snp2)

        with open(output[0], 'w') as f:
            for snp in sorted(remove_snps):
                f.write(f"{snp}\n")

rule filter_ld_beagle:
    """
    Create LD-pruned beagle file for PCA/Admixture
    - Removes high-LD SNPs identified by ld_prune
    - Ensures population structure analyses use independent SNPs
    - Critical for unbiased PCA/Admixture results

    Runtime: 3-5 minutes
    """
    input:
        beagle="results/angsd/all.beagle.gz",
        pruned="results/ld/pruned_snps.txt",
    output:
        beagle="results/angsd/all.ldpruned.beagle.gz",
    run:
        import gzip
        import sys

        # Load SNPs to remove
        with open(input.pruned) as f:
            remove_snps = set(line.strip() for line in f)

        # Filter beagle file
        with gzip.open(input.beagle, 'rt') as fin, \
             gzip.open(output.beagle, 'wt') as fout:

            # Copy header
            header = fin.readline()
            fout.write(header)

            # Filter data lines
            kept = 0
            removed = 0
            for line in fin:
                parts = line.strip().split('\t')
                marker = parts[0]  # Format: chr:pos or chr_pos

                if marker not in remove_snps:
                    fout.write(line)
                    kept += 1
                else:
                    removed += 1

            print(f"LD pruning: kept {kept} SNPs, removed {removed} high-LD SNPs", file=sys.stderr)

