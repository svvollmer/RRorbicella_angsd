rule sample_depth:
    container: "docker://quay.io/biocontainers/mulled-v2-bwa-samtools:0.7.17_1.17"
    input:
        "results/bams/{sample}.filtered.bam",
    output:
        "results/qc/{sample}.depth.txt",
    shell:
        "samtools depth -a {input} | awk '{{sum+=$3}} END {{print sum/NR}}' > {output}"

rule depth_summary:
    input:
        expand("results/qc/{sample}.depth.txt", sample=SAMPLES),
    output:
        "results/qc/depth_summary.txt",
    run:
        with open(output[0], 'w') as out:
            out.write("sample\tmean_depth\n")
            for f in input:
                sample = f.split('/')[-1].replace('.depth.txt', '')
                with open(f) as fh:
                    depth = fh.read().strip()
                out.write(f"{sample}\t{depth}\n")

rule filtering_summary:
    input:
        expand("results/qc/{sample}.flagstat.txt", sample=SAMPLES),
        expand("results/qc/{sample}.depth.txt", sample=SAMPLES),
    output:
        "results/filtering/filtering_summary.txt",
    run:
        with open(output[0], 'w') as out:
            out.write("Sample\tTotal_reads\tMapped_reads\tMapping_rate\tMean_depth\n")
            for sample in SAMPLES:
                flagstat_file = f"results/qc/{sample}.flagstat.txt"
                depth_file = f"results/qc/{sample}.depth.txt"

                with open(flagstat_file) as f:
                    lines = f.readlines()
                    total = lines[0].split()[0]
                    mapped = lines[4].split()[0]
                    rate = float(mapped) / float(total) if float(total) > 0 else 0

                with open(depth_file) as f:
                    depth = f.read().strip()

                out.write(f"{sample}\t{total}\t{mapped}\t{rate:.4f}\t{depth}\n")

