# 9. RELATEDNESS (uses all SNPs, not LD-pruned)
# ============================================================================

rule ngsrelate:
    """
    Relatedness/kinship analysis
    - Uses all SNPs (not LD-pruned) for better power
    - Identifies clones and close relatives
    - KING kinship estimator

    Runtime: 12-18 minutes
    """
    container: "docker://quay.io/biocontainers/ngsrelate:2.3.2--h9ee0642_0"
    input:
        beagle="results/angsd/all.beagle.gz",
        mafs="results/angsd/all.mafs.gz",
    output:
        "results/relatedness/relatedness.res",
    params:
        out="results/relatedness/relatedness",
        n_samples=N_SAMPLES,
    threads: 8
    shell:
        """
        mkdir -p results/relatedness
        N_SITES=$(python3 -c "import gzip; f=gzip.open('{input.mafs}','rt'); next(f); print(sum(1 for _ in f))")
        ngsRelate -G {input.beagle} -n {params.n_samples} -L $N_SITES -O {output} -p {threads}
        """

rule process_relatedness:
    """
    Process relatedness results
    - Creates pairwise kinship matrix
    - Flags clones and close relatives
    """
    input:
        "results/relatedness/relatedness.res",
    output:
        matrix="results/relatedness/relatedness_matrix.txt",
        summary="results/relatedness/relatedness_summary.txt",
    params:
        kinship_threshold=config.get("kinship_threshold", 0.2),
        clone_threshold=config.get("clone_threshold", 0.45),
    run:
        import pandas as pd
        rel = pd.read_csv(input[0], sep='\t')

        # Create matrix
        samples_list = SAMPLES
        matrix = pd.DataFrame(0.0, index=samples_list, columns=samples_list)
        for _, row in rel.iterrows():
            i, j = int(row['a']), int(row['b'])
            if i < len(samples_list) and j < len(samples_list):
                matrix.iloc[i, j] = row['KING']
                matrix.iloc[j, i] = row['KING']
        matrix.to_csv(output.matrix, sep='\t')

        # Summarize relationships
        with open(output.summary, 'w') as f:
            f.write("Sample_A\tSample_B\tKING\tRelationship\n")
            for _, row in rel.iterrows():
                king = row['KING']
                if king > params.clone_threshold:
                    relationship = "Clone/Identical"
                elif king > params.kinship_threshold:
                    relationship = "Close_relative"
                else:
                    continue

                ia, ib = int(row['a']), int(row['b'])
                if ia < len(SAMPLES) and ib < len(SAMPLES):
                    f.write(f"{SAMPLES[ia]}\t{SAMPLES[ib]}\t{king:.4f}\t{relationship}\n")

# ============================================================================
# 10. PER-POPULATION SAF → SFS → DIVERSITY → FST
# (Uses ALL sites including monomorphic for unbiased estimates)
# ============================================================================

rule angsd_saf:
    """
    Per-population site allele frequency likelihoods
    - Uses discovered SNP list from Pass 1 (not whole genome)
    - Processes ALL sites at those positions (no SNP filtering)
    - Critical: includes monomorphic sites for proper diversity estimates

    Runtime: 15-20 minutes per population
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h2add14b_0"
    input:
        bamlist="results/bamlists/{popname}.bamlist",
        ref=config["reference"],
        fai=config["reference"] + ".fai",
        sites="results/angsd/pass1_snps.txt",
    output:
        saf="results/sfs/{popname}.saf.idx",
    params:
        out="results/sfs/{popname}",
        gl=config.get("gl_model", 1),
    threads: 8
    shell:
        """
        mkdir -p results/sfs
        angsd sites index {input.sites}

        # Calculate SAF at discovered positions (includes monomorphic)
        angsd -bam {input.bamlist} -ref {input.ref} -anc {input.ref} \
            -out {params.out} \
            -GL {params.gl} -doSaf 1 \
            -sites {input.sites} \
            -minMapQ 20 -minQ 20 \
            -nThreads {threads}
        """

rule realsfs:
    """
    Estimate site frequency spectrum
    - Maximum likelihood estimation via EM algorithm
    - Includes monomorphic sites

    Runtime: 8-12 minutes per population
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h2add14b_0"
    input:
        "results/sfs/{popname}.saf.idx",
    output:
        "results/sfs/{popname}.sfs",
    threads: 8
    shell:
        "realSFS {input} -P {threads} > {output}"

rule thetas:
    """
    Calculate diversity statistics
    - Tajima's D, π (pi), Watterson's θ (theta)
    - Per-site and genome-wide estimates

    Runtime: 5-8 minutes per population
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h2add14b_0"
    input:
        saf="results/sfs/{popname}.saf.idx",
        sfs="results/sfs/{popname}.sfs",
    output:
        idx="results/diversity/{popname}.thetas.idx",
        pestpg="results/diversity/{popname}.thetas.idx.pestPG",
    params:
        out="results/diversity/{popname}",
    threads: 8
    shell:
        """
        mkdir -p results/diversity
        realSFS saf2theta {input.saf} -sfs {input.sfs} -outname {params.out} -P {threads}
        thetaStat do_stat {output.idx}
        """

rule realsfs_2d:
    """
    Estimate 2D site frequency spectrum
    - Joint SFS for two populations
    - Used as prior for FST calculation

    Runtime: 15-20 minutes
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h2add14b_0"
    input:
        saf1="results/sfs/{p1}.saf.idx",
        saf2="results/sfs/{p2}.saf.idx",
    output:
        "results/fst/{p1}_vs_{p2}.2dsfs",
    threads: 8
    shell:
        """
        mkdir -p results/fst
        realSFS {input.saf1} {input.saf2} -P {threads} > {output}
        """

rule fst_index:
    """
    Create FST index from 2D-SFS
    - Prepares for global and windowed FST calculation

    Runtime: 3-5 minutes
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h2add14b_0"
    input:
        saf1="results/sfs/{p1}.saf.idx",
        saf2="results/sfs/{p2}.saf.idx",
        sfs="results/fst/{p1}_vs_{p2}.2dsfs",
    output:
        "results/fst/{p1}_vs_{p2}.fst.idx",
    params:
        out="results/fst/{p1}_vs_{p2}",
    shell:
        "realSFS fst index {input.saf1} {input.saf2} -sfs {input.sfs} -fstout {params.out}"

rule fst_global:
    """
    Calculate global and windowed FST
    - Genome-wide FST between populations
    - 50kb windows with 10kb step for regional variation

    Runtime: 5-8 minutes
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h2add14b_0"
    input:
        "results/fst/{p1}_vs_{p2}.fst.idx",
    output:
        fst_global="results/fst/{p1}_vs_{p2}.fst.global",
        windows="results/fst/{p1}_vs_{p2}.fst.windows",
    shell:
        """
        realSFS fst stats {input} > {output.fst_global}
        realSFS fst stats2 {input} -win 50000 -step 10000 -type 2 > {output.windows}
        """

# ============================================================================
# 11. INDIVIDUAL HETEROZYGOSITY
# ============================================================================

rule individual_saf:
    """
    Per-individual SAF for heterozygosity estimation
    - Uses discovered SNP positions
    - Individual-level diversity metric

    Runtime: 12-15 minutes per sample
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h2add14b_0"
    input:
        bam="results/bams/{sample}.filtered.bam",
        ref=config["reference"],
        fai=config["reference"] + ".fai",
        sites="results/angsd/pass1_snps.txt",
    output:
        temp("results/heterozygosity/{sample}.saf.idx"),
    params:
        out="results/heterozygosity/{sample}",
        gl=config.get("gl_model", 1),
    threads: 4
    shell:
        """
        mkdir -p results/heterozygosity
        angsd sites index {input.sites}

        angsd -i {input.bam} -ref {input.ref} -anc {input.ref} \
            -GL {params.gl} -doSaf 1 \
            -sites {input.sites} \
            -minMapQ 20 -minQ 20 \
            -nThreads {threads} -out {params.out}
        """

rule individual_het:
    """
    Estimate individual heterozygosity
    - Genome-wide heterozygosity per sample

    Runtime: 1-2 minutes per sample
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h2add14b_0"
    input:
        "results/heterozygosity/{sample}.saf.idx",
    output:
        "results/heterozygosity/{sample}.het",
    shell:
        "realSFS {input} > {output}"

