rule download_sra:
    container: "docker://quay.io/biocontainers/sra-tools:3.0.10--h9f5acd7_0"
    output:
        r1=temp("results/fastq/{sample}_1.fastq.gz"),
        r2=temp("results/fastq/{sample}_2.fastq.gz"),
    params:
        acc=get_sra,
        tmpdir="tmp/{sample}",
    threads: 4
    shell:
        """
        mkdir -p {params.tmpdir}
        prefetch {params.acc} -O {params.tmpdir}
        fasterq-dump {params.tmpdir}/{params.acc} \
            -O results/fastq -e {threads} \
            --split-files --temp {params.tmpdir}
        gzip results/fastq/{params.acc}_1.fastq
        gzip results/fastq/{params.acc}_2.fastq
        mv results/fastq/{params.acc}_1.fastq.gz {output.r1}
        mv results/fastq/{params.acc}_2.fastq.gz {output.r2}
        rm -rf {params.tmpdir}
        """

rule fastp:
    container: "docker://quay.io/biocontainers/fastp:0.23.4--hadf994f_1"
    input:
        r1="results/fastq/{sample}_1.fastq.gz",
        r2="results/fastq/{sample}_2.fastq.gz",
    output:
        r1=temp("results/trimmed/{sample}_1.fastq.gz"),
        r2=temp("results/trimmed/{sample}_2.fastq.gz"),
        html="results/qc/{sample}_fastp.html",
        json="results/qc/{sample}_fastp.json",
    threads: 4
    shell:
        """
        fastp -i {input.r1} -I {input.r2} \
            -o {output.r1} -O {output.r2} \
            -h {output.html} -j {output.json} \
            --thread {threads} \
            --detect_adapter_for_pe \
            --cut_front --cut_tail \
            --trim_poly_g
        """

