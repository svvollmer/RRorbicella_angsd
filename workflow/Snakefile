rule make_gene_bed:
    container: "docker://quay.io/biocontainers/htslib:1.17--h6bc39ce_1"
    input:
        gff=config.get("gene_annotation", ""),
    output:
        bed="results/annotation/gene_regions.bed",
    shell:
        """
        mkdir -p results/annotation
        if [ -f {input.gff} ]; then
            grep -v "^#" {input.gff} \
                | awk '$3=="gene" {{print $1"\\t"$4-1"\\t"$5"\\t"$9}}' \
                > {output.bed}
        else
            touch {output.bed}
        fi
        """

rule annotate_fst_outliers:
    """
    Flag top 5% FST windows and intersect with gene annotations.
    """
    input:
        fst=[f"results/fst/{p[0]}_vs_{p[1]}.fst.windows" for p in POP_PAIRS] if len(POPS) > 1 else [],
        genes="results/annotation/gene_regions.bed",
    output:
        "results/annotation/fst_outliers_annotated.csv",
    run:
        if len(POPS) < 2 or not input.fst:
            with open(output[0], 'w') as f:
                f.write("chr,start,end,fst,comparison,overlapping_genes\n")
        else:
            import pandas as pd
            outliers = []
            for fst_file in input.fst:
                comp = fst_file.split('/')[-1].replace('.fst.windows', '')
                df = pd.read_csv(fst_file, sep='\t', header=None,
                                 names=['region', 'chr', 'midPos', 'Nsites', 'fst'])
                threshold = df['fst'].quantile(0.95)
                out = df[df['fst'] > threshold].copy()
                out['comparison'] = comp
                outliers.append(out)
            if outliers:
                pd.concat(outliers).to_csv(output[0], index=False)
            else:
                with open(output[0], 'w') as f:
                    f.write("chr,start,end,fst,comparison,overlapping_genes\n")

