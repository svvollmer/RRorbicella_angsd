rule download_sra:
    """
    Stream FASTQ directly from SRA — no prefetch, no intermediate .sra file.

    On AWS EC2 in us-east-1, NCBI automatically routes fasterq-dump to their
    free S3 bucket (sra-pub-run-odp), so data transfer costs nothing.
    Gzip both files in parallel to halve compression time.
    """
    # sra-tools container fasterq-dump has SSL/TLS issues on EC2; use host-installed version
    output:
        r1=temp("results/fastq/{sample}_1.fastq.gz"),
        r2=temp("results/fastq/{sample}_2.fastq.gz"),
    params:
        acc=get_sra,
        tmpdir="tmp/{sample}",
    threads: 4
    resources:
        mem_mb=8000,
        runtime=180,
    shell:
        """
        mkdir -p results/fastq {params.tmpdir}
        fasterq-dump {params.acc} \
            -O results/fastq -e {threads} \
            --split-files --temp {params.tmpdir}
        gzip results/fastq/{params.acc}_1.fastq &
        gzip results/fastq/{params.acc}_2.fastq &
        wait
        mv results/fastq/{params.acc}_1.fastq.gz {output.r1}
        mv results/fastq/{params.acc}_2.fastq.gz {output.r2}
        rm -rf {params.tmpdir}
        """

