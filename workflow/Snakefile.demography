"""
================================================================================
Snakefile.demography — Segment 6: Demographic Inference
================================================================================

Input:  results/bams/{sample}.filtered.BAM  (pre-existing BAMs on HPC)
        results/relatedness/unrelated_samples.txt  (from Segment 2)
        results/admixture/lineage_assignments.txt  (from Gate 3b)

Architecture (two analytical paths from K2/K3 admixture results):

  K2 path — hybridization / Apal-Acer species divergence
    Tests whether Apal–Acer gene flow is ongoing (IM), recent (SC), or ancient (AM)
    apal_vs_acer_fl   — FL Apal (FL_RR, n=76) vs all FL Acer (n=85)
    apal_vs_acer_bon  — BON Apal (n=24) vs BON Acer (n=24) [geographic replicate]

  K3 path — within-Acer geographic population structure
    acer_fl_vs_pa     — Florida Acer (n=85) vs Panama Acer (n=39)
    acer_fl_vs_bon    — Florida Acer (n=85) vs Bonaire Acer (n=24)
    acer_pa_vs_bon    — Panama Acer (n=39) vs Bonaire Acer (n=24)

Models fitted per comparison (moments, folded SFS, 20 random restarts each):
  SI   — strict isolation
  IM   — isolation with migration (symmetric)
  IM_a — isolation with migration (asymmetric)
  SC   — secondary contact (split → isolation → contact)
  AM   — ancient migration (split → migration → isolation)

Key design decisions:
  - Re-run ANGSD with -doSaf 1, NO MAF filter (existing SNP outputs
    used -minMaf 0.05 which truncates rare variants critical for demography)
  - SAF covers all non-repeat sites (monomorphic + variable)
  - Pairwise projections per comparison (80% of 2n, auto-calculated)
  - Folded SFS throughout (no reliable ancestral outgroup)
  - Geographic restriction: apal_fl = FL_RR only; apal_bon = BON only
    (avoids Wahlund effect from pooling FL+BON Apal into one SFS group)
================================================================================
"""

include: "common.smk"

import os
import json

PIPELINE = os.path.dirname(os.path.dirname(os.path.abspath(workflow.snakefile)))

# ---------------------------------------------------------------------------
# Demography config
# ---------------------------------------------------------------------------
DEMOG_CFG    = config.get("demography", {})
ADMIX_THRESH = DEMOG_CFG.get("admixture_threshold", 0.05)
DEMOG_PHASE  = DEMOG_CFG.get("phase", "florida_only")
DEMOG_COMPS  = DEMOG_CFG.get("demography_comparisons", [])
DEMOG_NAMES  = [c["name"] for c in DEMOG_COMPS]

# ---------------------------------------------------------------------------
# Load admixture-filtered sample lists
# admix_fraction comes from samples.csv (filled after PCAngsd Segment 3).
# Falls back to all unrelated samples if column absent.
# ---------------------------------------------------------------------------

def _load_unrelated():
    path = "results/relatedness/unrelated_samples.txt"
    if not os.path.exists(path):
        return set()
    with open(path) as f:
        return set(l.strip() for l in f if l.strip())

def get_demog_bamlist(group):
    """
    Resolve a demography group name to a list of sample IDs.

    Checks population_groups config first (explicit multi-population definitions).
    Falls back to the string-parsing convention for backward compatibility.
    """
    unrelated = _load_unrelated()

    # Check population_groups config first
    pop_groups = DEMOG_CFG.get("population_groups", {})
    if group in pop_groups:
        grp_def = pop_groups[group]
        sp   = grp_def.get("species")
        pops = grp_def.get("populations", [])
        mask = samples["sample_id"].isin(unrelated)
        if sp:
            mask &= samples["species"] == sp
        if pops:
            mask &= samples["population"].isin(pops)
        return samples.loc[mask, "sample_id"].tolist()

    # Parse suffixes
    admix_filter = None
    if group.endswith("_clean"):
        admix_filter = "clean"
        group = group[:-6]
    elif group.endswith("_admixed"):
        admix_filter = "admixed"
        group = group[:-8]

    # Parse species suffix (capitalized)
    species_filter = None
    for sp in (SPECIES or []):
        if group.endswith(f"_{sp}"):
            species_filter = sp
            group = group[:-(len(sp)+1)]
            break

    # Parse lineage prefix
    lineage_filter = None
    if HAS_LINEAGE:
        for lin in samples["lineage"].dropna().unique():
            if group.startswith(f"{lin}_"):
                lineage_filter = lin
                group = group[len(lin)+1:]
                break

    # Remaining token is population
    pop_filter = group

    mask = samples["sample_id"].isin(unrelated)
    if pop_filter:
        mask &= samples["population"] == pop_filter
    if species_filter:
        mask &= samples["species"] == species_filter
    if lineage_filter and HAS_LINEAGE:
        mask &= samples["lineage"] == lineage_filter
    if admix_filter and HAS_ADMIX:
        admix = pd.to_numeric(samples["admix_fraction"], errors="coerce").fillna(1.0)
        if admix_filter == "clean":
            mask &= admix < ADMIX_THRESH
        else:
            mask &= admix >= ADMIX_THRESH

    return samples.loc[mask, "sample_id"].tolist()


# ---------------------------------------------------------------------------
# Segment 6 targets
# ---------------------------------------------------------------------------
rule all:
    input:
        # Gate 4: clean/admixed bamlists per group (all comparisons)
        expand("results/demography/bamlists/{group}.bamlist",
               group=list({g for c in DEMOG_COMPS for g in c["groups"]})),
        # Gate 5: projection sizes
        expand("results/demography/projections/{name}.json", name=DEMOG_NAMES),
        # SAF files
        expand("results/demography/saf/{group}.saf.idx",
               group=list({g for c in DEMOG_COMPS for g in c["groups"]})),
        # 1D SFS
        expand("results/demography/sfs/{group}.sfs",
               group=list({g for c in DEMOG_COMPS for g in c["groups"]})),
        # 2D SFS per comparison (raw realSFS output)
        expand("results/demography/sfs2d/{name}.2dsfs", name=DEMOG_NAMES),
        # Inference results
        expand("results/demography/inference/{name}.moments.json", name=DEMOG_NAMES),
        expand("results/demography/inference/{name}.bestfit.txt", name=DEMOG_NAMES),

# ============================================================================
# GATE 4: Build bamlists filtered by admixture status
# ============================================================================

rule make_demog_bamlist:
    """
    Per-group bamlist for demography SAF runs.
    Reads admix_fraction from samples.csv (populated after PCAngsd).
    Falls back to all unrelated samples if admix_fraction column absent.
    """
    input:
        unrelated="results/relatedness/unrelated_samples.txt",
    output:
        bamlist="results/demography/bamlists/{group}.bamlist",
        n_samples="results/demography/bamlists/{group}.n.txt",
    wildcard_constraints:
        group="[a-zA-Z0-9_]+",
    run:
        sample_ids = get_demog_bamlist(wildcards.group)
        if not sample_ids:
            raise ValueError(
                f"No samples found for demography group '{wildcards.group}'. "
                f"Check demography_comparisons in config.yaml, lineage_assignments.txt, "
                f"and admix_fraction column in samples.csv."
            )
        with open(output.bamlist, 'w') as f:
            for sid in sample_ids:
                f.write(f"results/bams/{sid}.filtered.{BAM_EXT}\n")
        with open(output.n_samples, 'w') as f:
            f.write(f"{len(sample_ids)}\n")
        print(f"[demography] Group '{wildcards.group}': {len(sample_ids)} samples",
              file=__import__('sys').stderr)

# ============================================================================
# GATE 5: Calculate optimal projection sizes
# ============================================================================

rule calculate_projections:
    """
    Calculate optimal projection size for each demography comparison.
    Maximizes number of segregating sites in the projected SFS by
    finding the largest n where enough samples have sufficient coverage.
    Writes JSON with {group: n_haploids} per comparison.
    """
    input:
        n_samples=lambda wc: expand(
            "results/demography/bamlists/{group}.n.txt",
            group=[g for c in DEMOG_COMPS if c["name"] == wc.name for g in c["groups"]]
        ),
    output:
        "results/demography/projections/{name}.json",
    params:
        comp=lambda wc: next(c for c in DEMOG_COMPS if c["name"] == wc.name),
    run:
        comp = params.comp
        projection = comp.get("projection", None)
        if projection is None:
            # Auto-calculate: project to 80% of each group's sample count (haploids = 2n)
            ns = []
            for f in input.n_samples:
                with open(f) as fh:
                    ns.append(int(fh.read().strip()))
            projection = [int(n * 2 * 0.8) for n in ns]
        result = {g: p for g, p in zip(comp["groups"], projection)}
        import json
        with open(output[0], 'w') as f:
            json.dump(result, f, indent=2)
        print(f"[demography] Projections for '{comp['name']}': {result}",
              file=__import__('sys').stderr)

# ============================================================================
# SAF GENERATION (no MAF filter — monomorphic sites required for unbiased SFS)
# ============================================================================

rule angsd_saf_demography:
    """
    Per-group SAF over all non-repeat sites.
    NO MAF filter — monomorphic sites required for unbiased π/θ/D and SFS.
    Folded: reference used as ancestral (-anc = -ref), fold downstream.
    Note: existing SNP ANGSD outputs used -minMaf 0.05 — cannot reuse them.
    Runtime: 30-60 min per group on c6i.16xlarge.
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h13024bc_4"
    input:
        bamlist="results/demography/bamlists/{group}.bamlist",
        ref=config["reference"],
        fai=config["reference"] + ".fai",
        depth_thresh="results/angsd/depth_thresholds.txt",
        sites="results/angsd/nonrepeat_sites.txt",
        sites_idx="results/angsd/nonrepeat_sites.txt.idx",
        sites_bin="results/angsd/nonrepeat_sites.txt.bin",
    output:
        saf="results/demography/saf/{group}.saf.idx",
    wildcard_constraints:
        group="[a-zA-Z0-9_]+",
    params:
        out="results/demography/saf/{group}",
        gl=config.get("gl_model", 1),
        max_depth=lambda wc, input: (
            sum(1 for l in open(input.bamlist) if l.strip()) *
            int([l.split()[1] for l in open(input.depth_thresh)
                 if l.startswith('per_ind')][0])
        ),
        max_depth_ind=lambda wc, input: int(
            [l.split()[1] for l in open(input.depth_thresh)
             if l.startswith('per_ind')][0]
        ),
    threads: 8
    resources:
        mem_mb=16000,
        runtime=2880,
    shell:
        """
        mkdir -p results/demography/saf
        angsd -bam {input.bamlist} -ref {input.ref} -anc {input.ref} \
            -out {params.out} \
            -GL {params.gl} -doSaf 1 -doCounts 1 \
            -setMaxDepth {params.max_depth} \
            -setMaxDepthInd {params.max_depth_ind} \
            -setMinDepthInd 2 \
            -minMapQ 20 -minQ 20 \
            -remove_bads 1 -only_proper_pairs 1 \
            -sites {input.sites} \
            -nThreads {threads}
        """

# ============================================================================
# 1D SFS
# ============================================================================

rule realsfs_demography:
    """1D folded SFS via EM. Converges on tolerance (no maxIter cap)."""
    container: "docker://quay.io/biocontainers/angsd:0.940--h13024bc_4"
    input:
        "results/demography/saf/{group}.saf.idx",
    output:
        "results/demography/sfs/{group}.sfs",
    wildcard_constraints:
        group="[a-zA-Z0-9_]+",
    threads: 8
    resources:
        mem_mb=8000,
        runtime=2880,
    shell:
        "realSFS {input} -P {threads} -fold 1 > {output}"

# ============================================================================
# DADI-FORMAT SFS (per comparison)
# Uses realSFS dadi to produce a Data Dictionary suitable for dadi/moments.
# ============================================================================

rule realsfs_2dsfs:
    """
    Generate pairwise 2D SFS from two SAF files using realSFS.
    Output is a flat array of (2n1+1)*(2n2+1) floats, folded.
    Loaded by run_moments_2pop.py via --sfs-format realsfs.
    Note: realSFS dadi produces a per-site table, not a 2D spectrum —
    use plain realSFS for output that moments can directly consume.
    """
    container: "docker://quay.io/biocontainers/angsd:0.940--h13024bc_4"
    input:
        safs=lambda wc: expand(
            "results/demography/saf/{group}.saf.idx",
            group=[g for c in DEMOG_COMPS if c["name"] == wc.name for g in c["groups"]]
        ),
    output:
        "results/demography/sfs2d/{name}.2dsfs",
    threads: 8
    resources:
        mem_mb=16000,
        runtime=2880,
    shell:
        """
        mkdir -p results/demography/sfs2d
        realSFS {input.safs} -P {threads} -fold 1 > {output}
        """

# ============================================================================
# INFERENCE ENGINE
# ============================================================================

rule moments_2pop:
    """
    Two-population demographic model fitting with moments.
    Models: SI, IM, IM_a (asymmetric), SC (secondary contact), AM (ancient migration).
    Each model fit with {moments_restarts} random starts; best log-likelihood kept.
    AIC used for model comparison. Results written to JSON + human-readable summary.
    """
    input:
        sfs="results/demography/sfs2d/{name}.2dsfs",
        projections="results/demography/projections/{name}.json",
        n_files=lambda wc: expand(
            "results/demography/bamlists/{group}.n.txt",
            group=[g for c in DEMOG_COMPS if c["name"] == wc.name for g in c["groups"]]
        ),
    output:
        results="results/demography/inference/{name}.moments.json",
        bestfit="results/demography/inference/{name}.bestfit.txt",
    params:
        out=lambda wc: f"results/demography/inference/{wc.name}",
        restarts=DEMOG_CFG.get("moments_restarts", 20),
        models=" ".join(["SI", "IM", "IM_a", "SC", "AM"]),
        pop_ids=lambda wc: " ".join(
            next((c["groups"] for c in DEMOG_COMPS if c["name"] == wc.name), ["pop1", "pop2"])
        ),
        n_ind=lambda wc, input: " ".join(
            open(f).read().strip() for f in input.n_files
        ),
        python=config.get("python_path", "python"),
    threads: 8
    resources:
        mem_mb=8000,
        runtime=2880,
    shell:
        """
        mkdir -p results/demography/inference
        {params.python} {PIPELINE}/workflow/scripts/run_moments_2pop.py \
            --sfs {input.sfs} \
            --sfs-format realsfs \
            --n-ind {params.n_ind} \
            --projections {input.projections} \
            --pop-ids {params.pop_ids} \
            --out {params.out} \
            --restarts {params.restarts} \
            --threads {threads} \
            --models {params.models}
        """
