"""
================================================================================
Snakefile.smcpp — Segment 7: Population Size History (SMC++)
================================================================================

Input:  results/demography/bamlists/{Oannularis,Ofaveolata,Ofranksi}.bamlist
        results/angsd/nonrepeat_sites.txt   (callable sites mask)
        results/angsd/depth_thresholds.txt  (per-individual depth ceiling)

Steps:
  1. angsd_call  — ANGSD genotype calling -> per-chromosome BCF (persistent)
  2. bcf_to_vcf  — bcftools mpileup/call -> per-chromosome VCF.gz (temp)
  3. merge_vcf   — bcftools concat -> whole-genome VCF.gz per species
  4. make_mask   — nonrepeat sites -> bgzipped BED mask for SMC++
  5. vcf2smc     — smc++ vcf2smc: one file per chromosome x distinguished pair
  6. smc_fit     — smc++ estimate: Ne(t) model per species
  7. smc_plot    — smc++ plot: Ne(t) PNG + CSV

Splitting ANGSD (step 1) from bcftools (step 2) means a bcftools failure can
be re-run without repeating the expensive ANGSD genotyping step.

Note: smc++ split is NOT run — interspecific divergence exceeds SMC++ resolution
and causes OverflowError in the M-step. Use moments results (seg 6) for
divergence time estimates.

Setup (run once before launching seg 7):
  mkdir -p results/smcpp
  singularity pull results/smcpp/smcpp_latest.sif docker://terhorst/smcpp

Calibration:
  mutation_rate   = 1.8e-8  per bp per generation
  generation_time = 5 yr    (matches Acropora for comparability; true value ~5-10 yr)

Reference: O. franksi jaOrbFran1.1 / GCA_964199315.1
================================================================================
"""

include: "common.smk"

import os

SMCPP_SIF = "results/smcpp/smcpp_latest.sif"
ANGSD_SIF = "/work/vollmer/orbicella_genomics/.snakemake/singularity/084f8dcfcfe42901022fa6e05278b43b.simg"
BIND      = "--bind /work/vollmer --bind /projects/vollmer"
MUT_RATE  = 1.8e-8
GEN_TIME  = 5   # years; chosen to match Acropora for comparability (true value ~5-10 yr)

CHROMS = [
    "OZ116698.1", "OZ116699.1", "OZ116700.1", "OZ116701.1", "OZ116702.1",
    "OZ116703.1", "OZ116704.1", "OZ116705.1", "OZ116706.1", "OZ116707.1",
    "OZ116708.1", "OZ116709.1", "OZ116710.1", "OZ116711.1", "OZ116712.1",
]

# Short label -> lineage name in demography bamlists
SPECIES = {
    "oann": "Oannularis",
    "ofav": "Ofaveolata",
    "ofra": "Ofranksi",
}

N_PAIRS = 3  # distinguished pairs per chromosome for vcf2smc

# ---------------------------------------------------------------------------
rule all_smcpp:
    input:
        expand("results/smcpp/plots/{sp}_Ne.png", sp=SPECIES),
        expand("results/smcpp/plots/{sp}_Ne.csv", sp=SPECIES),
        "results/smcpp/plots/all_Ne.png",
        # split_Ne.png excluded: smc++ split fails for interspecific divergence
        # (OverflowError in M-step). Use moments results (seg 6) instead.

# ── 1. Per-chromosome BCF via ANGSD ─────────────────────────────────────────
rule angsd_call:
    """
    Genotype calling for SMC++ via ANGSD -> BCF.
    Output is kept (not temp) so bcf_to_vcf can be re-run independently
    without repeating the expensive ANGSD step.
    -minInd requires all samples to have data (appropriate for SMC++).
    """
    input:
        bamlist   = lambda wc: f"results/demography/bamlists/{SPECIES[wc.sp]}.bamlist",
        ref       = config["reference"],
        sites     = "results/angsd/nonrepeat_sites.txt",
        sites_idx = "results/angsd/nonrepeat_sites.txt.idx",
        sites_bin = "results/angsd/nonrepeat_sites.txt.bin",
        depth     = "results/angsd/depth_thresholds.txt",
    output:
        bcf = "results/smcpp/vcf/{sp}/{chrom}.bcf",
    params:
        out       = "results/smcpp/vcf/{sp}/{chrom}",
        max_depth = lambda wc, input: int(
            [l.split()[1] for l in open(input.depth)
             if l.startswith("total")][0]),
        n_samples = lambda wc: sum(
            1 for _ in open(
                f"results/demography/bamlists/{SPECIES[wc.sp]}.bamlist")),
    threads: 8
    resources:
        mem_mb  = 24000,
        runtime = 240,
    shell:
        """
        mkdir -p results/smcpp/vcf/{wildcards.sp}
        module load singularity/3.10.3
        singularity exec {BIND} {ANGSD_SIF} angsd \
            -bam {input.bamlist} \
            -ref {input.ref} \
            -r {wildcards.chrom}: \
            -sites {input.sites} \
            -GL 1 -doBcf 1 -doGeno 1 -doPost 1 \
            -doMajorMinor 1 -doMaf 1 -doCounts 1 \
            -SNP_pval 1e-6 \
            -minMapQ 20 -minQ 20 \
            -remove_bads 1 -only_proper_pairs 1 \
            -setMaxDepth {params.max_depth} \
            -minInd {params.n_samples} \
            -nThreads {threads} \
            -out {params.out}
        """

# ── 2. BCF -> VCF.gz via bcftools mpileup ───────────────────────────────────
rule bcf_to_vcf:
    """
    Joint genotype calling via bcftools mpileup + call.
    Uses BAMs directly (not ANGSD BCF output) because ANGSD hard-calls are
    all 0/0 for rare variants — population-level EM AF signal does not
    translate to individual GT calls. bcftools mpileup produces proper
    het/hom-alt calls needed by smc++ vcf2smc.
    ANGSD BCF is kept as a dependency (triggers step 1) but is not piped in.

    Each BAM is reheadered with the correct SM tag (sample name derived from
    filename) before mpileup, since all BAMs share SM:SampleName from alignment.
    """
    input:
        bcf      = "results/smcpp/vcf/{sp}/{chrom}.bcf",
        bamlist  = lambda wc: f"results/demography/bamlists/{SPECIES[wc.sp]}.bamlist",
        ref      = config["reference"],
        mask     = "results/smcpp/callable.bed.gz",
        mask_tbi = "results/smcpp/callable.bed.gz.tbi",
    output:
        vcf = temp("results/smcpp/vcf/{sp}/{chrom}.vcf.gz"),
        tbi = temp("results/smcpp/vcf/{sp}/{chrom}.vcf.gz.tbi"),
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 720,
    shell:
        """
        module load bcftools/1.21
        module load samtools/1.19.2

        WORK=$(mktemp -d /work/vollmer/orbicella_genomics/tmp_bcf2vcf.XXXXXXXX)
        trap "rm -rf $WORK" EXIT
        FIXED_BAMLIST="$WORK/bamlist.txt"
        > "$FIXED_BAMLIST"

        while IFS= read -r bam; do
            name=$(basename "$bam" .filtered.bam)
            region_bam="$WORK/${{name}}.bam"
            fixed_bam="$WORK/${{name}}.fixed.bam"
            hdr="$WORK/${{name}}.hdr.sam"

            samtools view -bh "$bam" {wildcards.chrom} > "$region_bam"
            samtools view -H "$region_bam" \
                | sed "s/SM:[^\\t]*/SM:$name/" > "$hdr"
            samtools reheader "$hdr" "$region_bam" > "$fixed_bam"
            samtools index "$fixed_bam"
            rm "$region_bam" "$hdr"
            echo "$fixed_bam" >> "$FIXED_BAMLIST"
        done < {input.bamlist}

        bcftools mpileup \
            --threads {threads} \
            -r {wildcards.chrom} \
            -T {input.mask} \
            -f {input.ref} \
            -b "$FIXED_BAMLIST" \
            -q 20 -Q 20 \
            --skip-indels \
            -a AD,DP,QS \
            -O u | \
        bcftools call -m -v -O z -o {output.vcf}
        bcftools index -t {output.vcf}
        """

# ── 3. Merge per-chromosome VCFs ────────────────────────────────────────────
rule merge_vcf:
    """
    Merge per-chromosome VCFs and reheader to short sample names.
    smc++ vcf2smc needs plain sample names matching the -d distinguished pair.
    Strips results/bams/<name>.filtered.bam -> <name>.
    Also writes a plain-text sample list for vcf2smc population definition.
    """
    input:
        vcfs = expand("results/smcpp/vcf/{{sp}}/{chrom}.vcf.gz", chrom=CHROMS),
        tbis = expand("results/smcpp/vcf/{{sp}}/{chrom}.vcf.gz.tbi", chrom=CHROMS),
    output:
        vcf  = "results/smcpp/vcf/{sp}.merged.vcf.gz",
        tbi  = "results/smcpp/vcf/{sp}.merged.vcf.gz.tbi",
        samp = "results/smcpp/vcf/{sp}.samples.txt",
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 480,
    shell:
        """
        module load bcftools/1.21
        bcftools concat --threads {threads} -O z \
            -o {output.vcf}.tmp.vcf.gz {input.vcfs}
        bcftools query -l {output.vcf}.tmp.vcf.gz \
            | sed 's|results/bams/||; s|\\.filtered\\.bam||' \
            > {output.vcf}.rename.txt
        bcftools reheader -s {output.vcf}.rename.txt \
            -o {output.vcf} {output.vcf}.tmp.vcf.gz
        bcftools index -t {output.vcf}
        bcftools query -l {output.vcf} > {output.samp}
        rm -f {output.vcf}.tmp.vcf.gz {output.vcf}.rename.txt
        """

# ── 4. Callable-sites mask (BED) ─────────────────────────────────────────────
rule make_mask:
    """Convert nonrepeat_sites.txt (1-based pos list) to bgzipped BED for SMC++."""
    input:
        sites = "results/angsd/nonrepeat_sites.txt",
    output:
        bed = "results/smcpp/callable.bed.gz",
        tbi = "results/smcpp/callable.bed.gz.tbi",
    resources:
        mem_mb  = 4000,
        runtime = 30,
    shell:
        """
        module load singularity/3.10.3
        module load bedtools/2.29.0
        awk 'NR>1 {{print $1"\\t"$2-1"\\t"$2}}' {input.sites} \
            | bedtools merge -i stdin \
            | singularity exec {BIND} {ANGSD_SIF} bgzip > {output.bed}
        singularity exec {BIND} {ANGSD_SIF} tabix -p bed {output.bed}
        """

# ── 5. vcf2smc — one file per chrom x distinguished pair ────────────────────
rule vcf2smc:
    """
    Convert merged VCF to SMC++ format per chromosome.
    N_PAIRS distinguished pairs per chromosome; smc++ estimate averages over all.
    Pairs are spaced evenly across the sample list.
    Population label matches the lineage name used in demography bamlists.
    """
    input:
        vcf  = "results/smcpp/vcf/{sp}.merged.vcf.gz",
        tbi  = "results/smcpp/vcf/{sp}.merged.vcf.gz.tbi",
        mask = "results/smcpp/callable.bed.gz",
        samp = "results/smcpp/vcf/{sp}.samples.txt",
    output:
        expand("results/smcpp/input/{{sp}}/{{chrom}}.pair{pair}.smc.gz",
               pair=range(1, N_PAIRS + 1)),
    params:
        pop_label = lambda wc: SPECIES[wc.sp],
        outdir    = "results/smcpp/input/{sp}",
        n_pairs   = N_PAIRS,
    resources:
        mem_mb  = 8000,
        runtime = 480,
    shell:
        """
        mkdir -p {params.outdir}
        module load singularity/3.10.3
        SAMP_ARR=( $(cat {input.samp}) )
        N=${{#SAMP_ARR[@]}}
        SAMPLES=$(IFS=,; echo "${{SAMP_ARR[*]}}")
        for pair in $(seq 1 {params.n_pairs}); do
            i1=$(( (pair - 1) * 2 % N ))
            i2=$(( ((pair - 1) * 2 + 1) % N ))
            D1=${{SAMP_ARR[$i1]}}
            D2=${{SAMP_ARR[$i2]}}
            singularity exec {BIND} {SMCPP_SIF} smc++ vcf2smc \
                --mask {input.mask} \
                -d $D1 $D2 \
                {input.vcf} \
                {params.outdir}/{wildcards.chrom}.pair${{pair}}.smc.gz \
                {wildcards.chrom} \
                {params.pop_label}:$SAMPLES
        done
        """

# ── 6. smc++ estimate ────────────────────────────────────────────────────────
rule smc_fit:
    """
    Fit piecewise-constant Ne(t) model via smc++ estimate.
    Cubic spline regularisation produces a smoother curve.
    """
    input:
        smcs = expand(
            "results/smcpp/input/{{sp}}/{chrom}.pair{pair}.smc.gz",
            chrom=CHROMS, pair=range(1, N_PAIRS + 1)),
    output:
        model = "results/smcpp/fit/{sp}/model.final.json",
    params:
        outdir = "results/smcpp/fit/{sp}",
        mu     = MUT_RATE,
    threads: 8
    resources:
        mem_mb          = 32000,
        runtime         = 2880,
        cpus_per_task   = 8,
        slurm_partition = "short",
        slurm_extra     = "'--mail-type=NONE' '--exclude=c3024,c3030'",
    shell:
        """
        mkdir -p {params.outdir}
        module load singularity/3.10.3
        singularity exec {BIND} {SMCPP_SIF} python3 /work/vollmer/orbicella_genomics/results/smcpp/smc_wrapper.py estimate \
            --cores {threads} \
            --spline cubic \
            --knots 10 \
            --em-iterations 20 \
            --regularization-penalty 6.0 \
            --ftol 1e-2 \
            --Nmin 1000 \
            -o {params.outdir} \
            {params.mu} \
            {input.smcs}
        """

# ── 7. smc++ plot ─────────────────────────────────────────────────────────────
rule smc_plot:
    """
    Plot Ne(t) curves. generation_time converts coalescent time to calendar years.
    Outputs combined PNG (all 3 species) and individual PNG + CSV per species.
    """
    input:
        models = expand("results/smcpp/fit/{sp}/model.final.json", sp=SPECIES),
    output:
        all_png = "results/smcpp/plots/all_Ne.png",
        sp_pngs = expand("results/smcpp/plots/{sp}_Ne.png", sp=SPECIES),
        sp_csvs = expand("results/smcpp/plots/{sp}_Ne.csv", sp=SPECIES),
    params:
        g      = GEN_TIME,
        outdir = "results/smcpp/plots",
    shell:
        """
        mkdir -p {params.outdir}
        module load singularity/3.10.3

        # Combined plot — all three species
        singularity exec {BIND} {SMCPP_SIF} smc++ plot \
            -g {params.g} \
            --csv \
            {params.outdir}/all_Ne.png \
            results/smcpp/fit/oann/model.final.json \
            results/smcpp/fit/ofav/model.final.json \
            results/smcpp/fit/ofra/model.final.json

        # Individual plots + CSVs
        for sp in oann ofav ofra; do
            singularity exec {BIND} {SMCPP_SIF} smc++ plot \
                -g {params.g} \
                --csv \
                {params.outdir}/${{sp}}_Ne.png \
                results/smcpp/fit/${{sp}}/model.final.json
        done
        """
