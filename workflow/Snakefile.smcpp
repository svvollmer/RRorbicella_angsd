"""
================================================================================
Snakefile.smcpp — Population size history via SMC++
================================================================================

Input:  results/smcpp/apal_fl_Q99.bamlist   (49 A. palmata FL, Q>=0.99)
        results/smcpp/acer_fl_Q99.bamlist   (82 A. cervicornis FL, Q>=0.99)
        results/angsd/nonrepeat_sites.txt   (callable sites mask)
        results/angsd/depth_thresholds.txt  (per-individual depth ceiling)

Steps:
  1. angsd_call  — ANGSD genotype calling -> per-chromosome BCF (persistent)
  2. bcf_to_vcf  — bcftools view -> per-chromosome VCF.gz + index (temp)
  3. merge_vcf   — bcftools concat -> whole-genome VCF.gz per species
  4. make_mask   — nonrepeat sites -> BED mask for SMC++
  5. vcf2smc     — smc++ vcf2smc: one file per chromosome x distinguished pair
  6. smc_fit     — smc++ fit: demographic model per species
  7. smc_plot    — smc++ plot: Ne(t) PNG

Splitting ANGSD (step 1) from bcftools conversion (step 2) means a bcftools
failure can be re-run without re-doing the expensive ANGSD genotyping.

Calibration:
  mutation_rate = 1.8e-8  (Acropora estimate; updated from literature)
  generation_time = 5     (years; branching Acropora sexual maturity)

SMC++ container: results/smcpp/smcpp_latest.sif
================================================================================
"""

include: "common.smk"

import os, glob

SMCPP_SIF  = "results/smcpp/smcpp_latest.sif"
ANGSD_SIF  = "/work/vollmer/acropora_genomics/.snakemake/singularity/084f8dcfcfe42901022fa6e05278b43b.simg"
BIND       = "--bind /projects --bind /work --bind /home --bind /tmp"
MUT_RATE   = 1.8e-8
GEN_TIME   = 5

CHROMS = [
    "NC_133882.1","NC_133883.1","NC_133884.1","NC_133885.1",
    "NC_133886.1","NC_133887.1","NC_133888.1","NC_133889.1",
    "NC_133890.1","NC_133891.1","NC_133892.1","NC_133893.1",
    "NC_133894.1","NC_133895.1",
]

SPECIES = {
    "apal": {"bamlist": "results/smcpp/apal_fl_Q99.bamlist",
             "samples": "results/smcpp/apal_fl_Q99.samples"},
    "acer": {"bamlist": "results/smcpp/acer_fl_Q99.bamlist",
             "samples": "results/smcpp/acer_fl_Q99.samples"},
}

# Number of distinguished pairs per species for vcf2smc
N_PAIRS = {"apal": 3, "acer": 5}
rule all_smcpp:
    input:
        expand("results/smcpp/plots/{sp}_Ne.png", sp=SPECIES),
        expand("results/smcpp/plots/{sp}_Ne.csv", sp=SPECIES),
        # split_Ne.png excluded: smc++ split fails for interspecific divergence
        # (OverflowError in exp() during M-step). Use moments/dadi instead (seg6).
# ── 1. Per-chromosome BCF via ANGSD ─────────────────────────────────────────
rule angsd_call:
    """
    Call genotypes for SMC++ using ANGSD -> BCF.
    Output is kept (not temp) so bcf_to_vcf can be re-run independently
    without repeating the expensive ANGSD step.
    """
    input:
        bamlist  = lambda wc: SPECIES[wc.sp]["bamlist"],
        ref      = config["reference"],
        sites    = "results/angsd/nonrepeat_sites.txt",
        sites_idx= "results/angsd/nonrepeat_sites.txt.idx",
        sites_bin= "results/angsd/nonrepeat_sites.txt.bin",
        depth    = "results/angsd/depth_thresholds.txt",
    output:
        bcf = "results/smcpp/vcf/{sp}/{chrom}.bcf",
    params:
        out       = "results/smcpp/vcf/{sp}/{chrom}",
        max_depth = lambda wc, input: int(
            [l.split()[1] for l in open(input.depth) if l.startswith("total")][0]),
        n_samples = lambda wc: sum(1 for _ in open(SPECIES[wc.sp]["bamlist"])),
    threads: 8
    resources:
        mem_mb  = 24000,
        runtime = 240,
    shell:
        """
        mkdir -p results/smcpp/vcf/{wildcards.sp}
        module load singularity/3.10.3
        singularity exec {BIND} {ANGSD_SIF} angsd \
            -bam {input.bamlist} \
            -ref {input.ref} \
            -r {wildcards.chrom}: \
            -sites {input.sites} \
            -GL 1 -doBcf 1 -doGeno 1 -doPost 1 -doMajorMinor 1 -doMaf 1 -doCounts 1 \
            -SNP_pval 1e-6 \
            -minMapQ 20 -minQ 20 \
            -remove_bads 1 -only_proper_pairs 1 \
            -setMaxDepth {params.max_depth} \
            -minInd {params.n_samples} \
            -nThreads {threads} \
            -out {params.out}
        """
# ── 2. BCF -> VCF.gz ─────────────────────────────────────────────────────────
rule bcf_to_vcf:
    """
    Call variants per-chromosome using bcftools mpileup + call.
    Uses BAMs directly (not ANGSD BCF) because ANGSD hard-calls are all 0/0
    for rare variants (population-level EM AF signal does not translate to
    individual-level GT calls). bcftools mpileup joint-calling produces
    proper het/hom-alt calls needed by smc++ vcf2smc.
    ANGSD BCF kept as dependency (already computed; no re-run needed).
    """
    input:
        bcf     = "results/smcpp/vcf/{sp}/{chrom}.bcf",
        bamlist = lambda wc: SPECIES[wc.sp]["bamlist"],
        ref     = config["reference"],
        mask    = "results/smcpp/callable.bed.gz",
        mask_tbi= "results/smcpp/callable.bed.gz.tbi",
    output:
        vcf = temp("results/smcpp/vcf/{sp}/{chrom}.vcf.gz"),
        tbi = temp("results/smcpp/vcf/{sp}/{chrom}.vcf.gz.tbi"),
    threads: 4
    resources:
        mem_mb  = 16000,
        runtime = 720,
    shell:
        """
        module load bcftools/1.21
        module load samtools/1.19.2

        # All BAMs have SM:SampleName in their headers (set at alignment time),
        # so bcftools mpileup merges all samples into one column.  Fix by
        # extracting the per-chromosome region for each BAM and reheadering
        # with the correct SM tag (derived from the filename) before calling.
        WORK=$(mktemp -d /work/vollmer/acropora_genomics/tmp_bcf2vcf.XXXXXXXX)
        trap "rm -rf $WORK" EXIT
        FIXED_BAMLIST="$WORK/bamlist.txt"
        > "$FIXED_BAMLIST"

        while IFS= read -r bam; do
            name=$(basename "$bam" .filtered.bam)
            region_bam="$WORK/${{name}}.bam"
            fixed_bam="$WORK/${{name}}.fixed.bam"
            hdr="$WORK/${{name}}.hdr.sam"

            # Extract chromosome region (much smaller than full BAM)
            samtools view -bh "$bam" {wildcards.chrom} > "$region_bam"

            # Write corrected header (replace SM:SampleName with actual name)
            samtools view -H "$region_bam" \
                | sed "s/SM:[^\\t]*/SM:$name/" > "$hdr"

            # Apply new header and index
            samtools reheader "$hdr" "$region_bam" > "$fixed_bam"
            samtools index "$fixed_bam"
            rm "$region_bam" "$hdr"

            echo "$fixed_bam" >> "$FIXED_BAMLIST"
        done < {input.bamlist}

        bcftools mpileup \
            --threads {threads} \
            -r {wildcards.chrom} \
            -T {input.mask} \
            -f {input.ref} \
            -b "$FIXED_BAMLIST" \
            -q 20 -Q 20 \
            --skip-indels \
            -a AD,DP,QS \
            -O u | \
        bcftools call -m -v -O z -o {output.vcf}
        bcftools index -t {output.vcf}
        """
# ── 3. Merge per-chromosome VCFs ────────────────────────────────────────────
rule merge_vcf:
    """
    Merge per-chromosome VCFs and reheader to use short sample names.
    ANGSD writes full BAM paths as VCF sample IDs; smc++ vcf2smc needs
    plain sample names matching the -d distinguished-lineage argument.
    Reheader strips results/bams/<name>.filtered.bam -> <name>.
    """
    input:
        vcfs = expand("results/smcpp/vcf/{{sp}}/{chrom}.vcf.gz", chrom=CHROMS),
        tbis = expand("results/smcpp/vcf/{{sp}}/{chrom}.vcf.gz.tbi", chrom=CHROMS),
        samp = lambda wc: SPECIES[wc.sp]["samples"],
    output:
        vcf = "results/smcpp/vcf/{sp}.merged.vcf.gz",
        tbi = "results/smcpp/vcf/{sp}.merged.vcf.gz.tbi",
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 480,
    shell:
        """
        module load bcftools/1.21
        # Merge chromosomes
        bcftools concat --threads {threads} -O z -o {output.vcf}.tmp.vcf.gz {input.vcfs}
        # Build rename map: full BAM path -> short sample name
        bcftools query -l {output.vcf}.tmp.vcf.gz \
            | sed 's|results/bams/||; s|\.filtered\.bam||' \
            > {output.vcf}.samples.txt
        # Reheader with short names
        bcftools reheader -s {output.vcf}.samples.txt -o {output.vcf} {output.vcf}.tmp.vcf.gz
        bcftools index -t {output.vcf}
        rm -f {output.vcf}.tmp.vcf.gz {output.vcf}.samples.txt
        """
# ── 4. Callable-sites mask (BED) ─────────────────────────────────────────────
rule make_mask:
    """Convert nonrepeat_sites.txt (pos list) to BED for SMC++ --mask."""
    input:
        sites = "results/angsd/nonrepeat_sites.txt",
        fai   = config["reference"] + ".fai",
    output:
        bed = "results/smcpp/callable.bed.gz",
    resources:
        mem_mb  = 4000,
        runtime = 30,
    shell:
        """
        module load singularity/3.10.3
        module load bedtools/2.29.0
        # Convert 1-based sites list to 0-based BED, merge adjacent positions
        # bgzip/tabix from ANGSD container (not available as host modules)
        awk 'NR>1 {{print $1"\t"$2-1"\t"$2}}' {input.sites} \
            | bedtools merge -i stdin \
            | singularity exec {BIND} {ANGSD_SIF} bgzip > {output.bed}
        singularity exec {BIND} {ANGSD_SIF} tabix -p bed {output.bed}
        """
# ── 5. vcf2smc — one file per chrom x distinguished pair ────────────────────
rule vcf2smc:
    """
    Convert VCF to SMC++ format for one chromosome.
    Runs N_PAIRS distinguished pairs (randomly selected); SMC++ averages over them.
    -d flag specifies the distinguished pair (the two haplotypes explicitly tracked).
    """
    input:
        vcf  = "results/smcpp/vcf/{sp}.merged.vcf.gz",
        tbi  = "results/smcpp/vcf/{sp}.merged.vcf.gz.tbi",
        mask = "results/smcpp/callable.bed.gz",
        samp = lambda wc: SPECIES[wc.sp]["samples"],
    output:
        expand("results/smcpp/input/{{sp}}/{{chrom}}.pair{pair}.smc.gz",
               pair=range(1, 4)),  # always 3 pairs; SMC++ can handle extras
    params:
        pop_label = "{sp}",
    resources:
        mem_mb  = 8000,
        runtime = 480,
    shell:
        """
        mkdir -p results/smcpp/input/{wildcards.sp}
        module load singularity/3.10.3
        module load bcftools/1.21
        # Sample names in VCF are now short (reheadered in merge_vcf)
        SAMP_ARR=( $(bcftools query -l {input.vcf}) )
        N=${{#SAMP_ARR[@]}}
        SAMPLES=$(IFS=,; echo "${{SAMP_ARR[*]}}")
        for pair in 1 2 3; do
            # pick two distinct samples for distinguished pair
            i1=$(( (pair - 1) * 2 % N ))
            i2=$(( (pair - 1) * 2 + 1 % N ))
            D1=${{SAMP_ARR[$i1]}}
            D2=${{SAMP_ARR[$i2]}}
            singularity exec {BIND} {SMCPP_SIF} smc++ vcf2smc \
                -d $D1 $D2 \
                {input.vcf} \
                results/smcpp/input/{wildcards.sp}/{wildcards.chrom}.pair${{pair}}.smc.gz \
                {wildcards.chrom} \
                {params.pop_label}:$SAMPLES
        done
        """
# ── 6. smc++ fit ─────────────────────────────────────────────────────────────
rule smc_fit:
    """
    Fit piecewise-constant population size model via SMC++.
    --spline: cubic spline regularisation (smoother curve)
    -o: output directory (contains model.final.json)
    mutation_rate passed as positional argument
    """
    input:
        smcs = expand(
            "results/smcpp/input/{{sp}}/{chrom}.pair{pair}.smc.gz",
            chrom=CHROMS, pair=[1,2,3]),
    output:
        model = "results/smcpp/fit/{sp}/model.final.json",
    params:
        outdir = "results/smcpp/fit/{sp}",
        mu     = MUT_RATE,
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 240,
    shell:
        """
        mkdir -p {params.outdir}
        module load singularity/3.10.3
        singularity exec {BIND} {SMCPP_SIF} smc++ estimate \
            --cores {threads} \
            --spline cubic \
            -o {params.outdir} \
            {params.mu} \
            {input.smcs}
        """
# ── 7. smc++ plot ─────────────────────────────────────────────────────────────
rule smc_plot:
    """
    Plot Ne(t) curves. generation_time converts coalescent time to years.
    Outputs PNG + CSV for downstream analysis.
    """
    input:
        models = expand("results/smcpp/fit/{sp}/model.final.json", sp=SPECIES),
    output:
        png = expand("results/smcpp/plots/{sp}_Ne.png", sp=SPECIES),
        csv = expand("results/smcpp/plots/{sp}_Ne.csv", sp=SPECIES),
    params:
        g      = GEN_TIME,
        outdir = "results/smcpp/plots",
    shell:
        """
        mkdir -p {params.outdir}
        module load singularity/3.10.3
        # Plot both species together
        singularity exec {BIND} {SMCPP_SIF} smc++ plot \
            -g {params.g} \
            --csv \
            {params.outdir}/both_Ne.png \
            {input.models}
        # Individual plots + CSVs
        for sp in apal acer; do
            singularity exec {BIND} {SMCPP_SIF} smc++ plot \
                -g {params.g} \
                --csv \
                {params.outdir}/${{sp}}_Ne.png \
                results/smcpp/fit/${{sp}}/model.final.json
        done
        """
# ── 8. Combined VCF for split analysis ───────────────────────────────────────
rule merge_combined_vcf:
    """
    Merge apal and acer per-species VCFs into a single multi-population VCF
    for smc++ split (divergence time estimation).
    Sites present in only one species get ./. for the other.
    """
    input:
        apal = "results/smcpp/vcf/apal.merged.vcf.gz",
        apal_tbi = "results/smcpp/vcf/apal.merged.vcf.gz.tbi",
        acer = "results/smcpp/vcf/acer.merged.vcf.gz",
        acer_tbi = "results/smcpp/vcf/acer.merged.vcf.gz.tbi",
    output:
        vcf = "results/smcpp/vcf/combined.merged.vcf.gz",
        tbi = "results/smcpp/vcf/combined.merged.vcf.gz.tbi",
    threads: 4
    resources:
        mem_mb  = 8000,
        runtime = 120,
    shell:
        """
        module load bcftools/1.21
        bcftools merge --threads {threads} -O z -o {output.vcf} \
            {input.apal} {input.acer}
        bcftools index -t {output.vcf}
        """
# ── 9. vcf2smc for split (joint two-population files) ────────────────────────
rule vcf2smc_split:
    """
    Convert combined VCF to SMC++ format with both populations labelled.
    Distinguished pair drawn from apal (pop1); acer is pop2.
    3 pairs per chromosome, matching single-species convention.
    """
    input:
        vcf  = "results/smcpp/vcf/combined.merged.vcf.gz",
        tbi  = "results/smcpp/vcf/combined.merged.vcf.gz.tbi",
        mask = "results/smcpp/callable.bed.gz",
        apal_samp = SPECIES["apal"]["samples"],
        acer_samp = SPECIES["acer"]["samples"],
    output:
        expand("results/smcpp/input/split/{{chrom}}.pair{pair}.smc.gz",
               pair=[1, 2, 3]),
    resources:
        mem_mb  = 8000,
        runtime = 480,
    shell:
        """
        mkdir -p results/smcpp/input/split
        module load singularity/3.10.3
        module load bcftools/1.21
        APAL_SAMPS=$(paste -sd, {input.apal_samp})
        ACER_SAMPS=$(paste -sd, {input.acer_samp})
        APAL_ARR=( $(cat {input.apal_samp}) )
        N=${{#APAL_ARR[@]}}
        for pair in 1 2 3; do
            i1=$(( (pair - 1) * 2 % N ))
            i2=$(( (pair - 1) * 2 + 1 % N ))
            D1=${{APAL_ARR[$i1]}}
            D2=${{APAL_ARR[$i2]}}
            singularity exec {BIND} {SMCPP_SIF} smc++ vcf2smc \
                -d $D1 $D2 \
                {input.vcf} \
                results/smcpp/input/split/{wildcards.chrom}.pair${{pair}}.smc.gz \
                {wildcards.chrom} \
                apal:$APAL_SAMPS \
                acer:$ACER_SAMPS
        done
        """
# ── 10. smc++ split — divergence time estimation ─────────────────────────────
rule smc_split:
    """
    Estimate apal/acer divergence time using per-species Ne models as priors.
    smc++ split refines the split time parameter T while fixing Ne trajectories.
    """
    input:
        apal_model = "results/smcpp/fit/apal/model.final.json",
        acer_model = "results/smcpp/fit/acer/model.final.json",
        smcs = expand("results/smcpp/input/split/{chrom}.pair{pair}.smc.gz",
                      chrom=CHROMS, pair=[1, 2, 3]),
    output:
        model = "results/smcpp/split/model.final.json",
    params:
        outdir = "results/smcpp/split",
    threads: 8
    resources:
        mem_mb  = 16000,
        runtime = 240,
    shell:
        """
        mkdir -p {params.outdir}
        module load singularity/3.10.3
        singularity exec {BIND} {SMCPP_SIF} smc++ split \
            --cores {threads} \
            -o {params.outdir} \
            {input.apal_model} \
            {input.acer_model} \
            {input.smcs}
        """
# ── 11. Plot split model ──────────────────────────────────────────────────────
rule plot_split:
    """
    Plot Ne(t) + divergence time from smc++ split model.
    """
    input:
        apal_model = "results/smcpp/fit/apal/model.final.json",
        acer_model = "results/smcpp/fit/acer/model.final.json",
        split_model = "results/smcpp/split/model.final.json",
    output:
        png = "results/smcpp/plots/split_Ne.png",
        csv = "results/smcpp/plots/split_Ne.csv",
    params:
        g = GEN_TIME,
    shell:
        """
        mkdir -p results/smcpp/plots
        module load singularity/3.10.3
        singularity exec {BIND} {SMCPP_SIF} smc++ plot \
            -g {params.g} \
            --csv \
            {output.png} \
            {input.apal_model} \
            {input.acer_model} \
            {input.split_model}
        """
